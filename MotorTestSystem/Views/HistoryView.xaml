                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedMotor.IsFwdNoiseAbnormal}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource AccentRed}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                                            <TextBlock Text="反转综合噪音" Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding SelectedMotor.RevNoiseText, StringFormat=\{0\} dB}" FontSize="14" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedMotor.IsRevNoiseAbnormal}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource AccentRed}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Row 2: Load Current & Speed -->
                                        <StackPanel Grid.Row="2" Grid.Column="0">
                                            <TextBlock Text="负载电流" Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding SelectedMotor.LoadCurrentText, StringFormat=\{0\} A}" FontSize="14" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedMotor.IsLoadCurrentAbnormal}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource AccentRed}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Row="2" Grid.Column="1">
                                            <TextBlock Text="负载转速" Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding SelectedMotor.LoadSpeedText, StringFormat=\{0\} r/min}" FontSize="14" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedMotor.IsLoadSpeedAbnormal}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource AccentRed}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Waveform Visualization Block -->
                                <Grid Margin="0,15,0,15">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="140"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="140"/>
                                    </Grid.RowDefinitions>

                                    <!-- 空载电流波形 -->
                                    <Grid Grid.Row="0" Margin="0,0,0,6">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                            <Border Width="3" Height="12" Background="#00DFFF" CornerRadius="1.5" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="空载电流波形" Foreground="{DynamicResource TextPrimary}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <TextBlock Text="（启动冲击 → 稳态波动）" Foreground="{DynamicResource TextSecondary}" FontSize="10" Margin="8,0,0,0" VerticalAlignment="Center" Opacity="0.7"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Ellipse Width="6" Height="6" Fill="#00DFFF" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="当前电流" Foreground="{DynamicResource TextSecondary}" FontSize="10" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                            <Ellipse Width="6" Height="6" Fill="#F74C5B" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="上限 (2.5A)" Foreground="{DynamicResource TextSecondary}" FontSize="10" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                    <Border Grid.Row="1" Background="#181924" CornerRadius="6" BorderBrush="#333645" BorderThickness="1" Padding="4">
                                        <lvc:CartesianChart Background="Transparent"
                                                            Series="{Binding NoLoadWaveformSeries}"
                                                            XAxes="{Binding WaveformXAxes}"
                                                            YAxes="{Binding NoLoadWaveformYAxes}"
                                                            TooltipBackgroundPaint="{Binding WaveformTooltipBgPaint}"
                                                            TooltipTextPaint="{Binding WaveformTooltipTextPaint}"
                                                            TooltipTextSize="11"
                                                            ZoomMode="X"
                                                            LegendPosition="Hidden"/>
                                    </Border>

                                    <!-- 噪音波形 -->
                                    <Grid Grid.Row="3" Margin="0,0,0,6">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                            <Border Width="3" Height="12" Background="#FFA500" CornerRadius="1.5" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="噪音波形" Foreground="{DynamicResource TextPrimary}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <TextBlock Text="（正转 / 反转）" Foreground="{DynamicResource TextSecondary}" FontSize="10" Margin="8,0,0,0" VerticalAlignment="Center" Opacity="0.7"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Ellipse Width="6" Height="6" Fill="#FFA500" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="正转噪音" Foreground="{DynamicResource TextSecondary}" FontSize="10" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                            <Ellipse Width="6" Height="6" Fill="#A855F7" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="反转噪音" Foreground="{DynamicResource TextSecondary}" FontSize="10" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                            <Ellipse Width="6" Height="6" Fill="#F74C5B" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="上限 (70dB)" Foreground="{DynamicResource TextSecondary}" FontSize="10" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                    <Border Grid.Row="4" Background="#181924" CornerRadius="6" BorderBrush="#333645" BorderThickness="1" Padding="4">
                                        <lvc:CartesianChart Background="Transparent"
                                                            Series="{Binding NoiseWaveformSeries}"
                                                            XAxes="{Binding WaveformXAxes}"
                                                            YAxes="{Binding NoiseWaveformYAxes}"
                                                            TooltipBackgroundPaint="{Binding WaveformTooltipBgPaint}"
                                                            TooltipTextPaint="{Binding WaveformTooltipTextPaint}"
                                                            TooltipTextSize="11"
                                                            ZoomMode="X"
                                                            LegendPosition="Hidden"/>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Action Buttons: Print Trace & View Full Report -->
                        <Grid Grid.Row="2" Margin="0,5,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Print button -->
                            <Button Grid.Column="0" Command="{Binding PrintTraceCommand}" Height="36" Background="#2B303C" Foreground="{DynamicResource TextPrimary}" BorderBrush="#3B4254" BorderThickness="1" Margin="0,0,5,0">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Path Data="M18,3H6V7H18M19,12A1,1 0 0,1 18,11A1,1 0 0,1 17,12A1,1 0 0,1 18,13A1,1 0 0,1 19,12M16,19H8V14H16M19,8H5A3,3 0 0,0 2,11V17H6V21H18V17H22V11A3,3 0 0,0 19,8Z" Fill="{DynamicResource TextPrimary}" Width="14" Height="14" Stretch="Fill" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="打印追溯单" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>

                            <!-- View Report button -->
                            <Button Grid.Column="1" Command="{Binding ViewReportCommand}" Height="36" Background="{DynamicResource AccentCyan}" Foreground="Black" BorderThickness="0" Margin="5,0,0,0">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Path Data="M13,9H18.5L13,3.5V9M6,2H14L20,8V20A2,2 0 0,1 18,22H6C4.89,22 4,21.1 4,20V4C4,2.89 4.89,2 6,2M7,20H17V18H7V20M7,16H17V14H7V16M7,12H13V10H7V12Z" Fill="Black" Width="14" Height="14" Stretch="Fill" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="查看完整报告" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ROW 4: BOTTOM PAGINATION & ACTIONS -->
        <Grid Grid.Row="4" Margin="20,0,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Pagination Controls (Left) -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Prev Page Button -->
                <Button Content="&lt; 上一页" 
                        Command="{Binding PreviousPageCommand}" 
                        Background="#2B303C" Foreground="White" BorderThickness="0" 
                        Height="28" Padding="12,0,12,0" FontWeight="SemiBold" FontSize="11" Margin="0,0,15,0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <!-- Page Info -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                    <TextBlock Text="第 " Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                    <TextBlock Text="{Binding CurrentPage}" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" FontSize="12"/>
                    <TextBlock Text=" 页 / 共 " Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                    <TextBlock Text="{Binding TotalPages}" Foreground="{DynamicResource TextPrimary}" FontWeight="Bold" FontSize="12"/>
                    <TextBlock Text=" 页" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                </StackPanel>

                <!-- Next Page Button -->
                <Button Content="下一页 &gt;" 
                        Command="{Binding NextPageCommand}" 
                        Background="#2B303C" Foreground="White" BorderThickness="0" 
                        Height="28" Padding="12,0,12,0" FontWeight="SemiBold" FontSize="11" Margin="0,0,20,0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <!-- Total Count Info using Run for rich styling -->
                <TextBlock VerticalAlignment="Center">
                    <Run Text="共 " Foreground="{DynamicResource TextSecondary}"/>
                    <Run Text="{Binding TotalTestsCount}" Foreground="{DynamicResource AccentCyan}" FontWeight="Bold"/>
                    <Run Text=" 条测试数据" Foreground="{DynamicResource TextSecondary}"/>
                </TextBlock>
            </StackPanel>

            <!-- Export Button (Right) -->
            <Button Grid.Column="1" 
                    Command="{Binding ExportCommand}" 
                    Background="{DynamicResource AccentCyan}" Foreground="Black" BorderThickness="0" 
                    Height="32" Padding="15,0,15,0" FontWeight="Bold" FontSize="12">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
                <StackPanel Orientation="Horizontal">
                    <Path Data="M5,20H19V18H5M19,9H15V3H9V9H5L12,16L19,9Z" 
                          Fill="Black" Width="14" Height="14" Stretch="Fill" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="导出数据" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- 打印进度浮层 -->
        <Grid Panel.ZIndex="1000"
              Visibility="{Binding IsPrinting, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
            <Grid.Background>
                <SolidColorBrush Color="#13141E" Opacity="0.75"/>
            </Grid.Background>
            <Border Background="#212431" CornerRadius="12" BorderBrush="#333645" BorderThickness="1"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Padding="40,30">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <!-- 旋转动画圆环 -->
                    <Grid Width="32" Height="32" Margin="0,0,16,0">
                        <Ellipse Stroke="#333645" StrokeThickness="3" Width="32" Height="32"/>
                        <Ellipse Stroke="{DynamicResource AccentCyan}" StrokeThickness="3"
                                 StrokeDashArray="40,100" Width="32" Height="32"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <RotateTransform x:Name="PrintSpinnerRotate" Angle="0"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="PrintSpinnerRotate"
                                                             Storyboard.TargetProperty="Angle"
                                                             From="0" To="360" Duration="0:0:1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                    </Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="正在打印追溯单" Foreground="White" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding PrintStatus}" Foreground="#8A8D99" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
