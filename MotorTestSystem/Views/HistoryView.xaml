<UserControl x:Class="MotorTestSystem.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MotorTestSystem.Views"
             xmlns:conv="clr-namespace:MotorTestSystem.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">

    <UserControl.Resources>
        <conv:ResultToBrushConverter x:Key="ResultToBrushConverter"/>
    </UserControl.Resources>

    <Grid Background="#12141A">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TITLE -->
        <TextBlock Text="历史数据查询与追溯" Foreground="White" FontSize="22" FontWeight="Bold" Margin="20,15,20,10"/>

        <!-- FILTER BAR -->
        <Border Grid.Row="1" Background="#1B1E26" BorderBrush="#2B303C" BorderThickness="1" CornerRadius="8" Margin="20,5,20,15" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.5*"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search Barcode -->
                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                    <TextBlock Text="电机条码" Foreground="#A0AAB2" FontSize="12" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding SearchBarcode, UpdateSourceTrigger=PropertyChanged}" 
                             Background="#12141A" Foreground="White" BorderBrush="#2B303C" Height="30" Padding="5,0,0,0" VerticalContentAlignment="Center"/>
                </StackPanel>

                <!-- Result Filter -->
                <StackPanel Grid.Column="1" Margin="0,0,15,0">
                    <TextBlock Text="测试结果" Foreground="#A0AAB2" FontSize="12" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding ResultFilters}" 
                              SelectedItem="{Binding SelectedResultFilter}" 
                              Background="#12141A" Foreground="Black" BorderBrush="#2B303C" Height="30" VerticalContentAlignment="Center"/>
                </StackPanel>

                <!-- Start Date -->
                <StackPanel Grid.Column="2" Margin="0,0,15,0">
                    <TextBlock Text="开始日期" Foreground="#A0AAB2" FontSize="12" Margin="0,0,0,5"/>
                    <DatePicker SelectedDate="{Binding StartDate}" 
                                Height="30" VerticalContentAlignment="Center"/>
                </StackPanel>

                <!-- End Date -->
                <StackPanel Grid.Column="3" Margin="0,0,15,0">
                    <TextBlock Text="结束日期" Foreground="#A0AAB2" FontSize="12" Margin="0,0,0,5"/>
                    <DatePicker SelectedDate="{Binding EndDate}" 
                                Height="30" VerticalContentAlignment="Center"/>
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Content="查询" 
                            Command="{Binding SearchCommand}" 
                            Width="75" Height="30" 
                            Background="#00DFFF" Foreground="Black" 
                            FontWeight="Bold" BorderThickness="0" Margin="0,0,10,0"/>
                    <Button Content="重置" 
                            Command="{Binding ResetCommand}" 
                            Width="75" Height="30" 
                            Background="#2B303C" Foreground="White" 
                            FontWeight="Bold" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DATAGRID PANEL -->
        <Border Grid.Row="2" Background="#1B1E26" BorderBrush="#2B303C" BorderThickness="1" CornerRadius="8" Margin="20,0,20,15" Padding="10">
            <DataGrid ItemsSource="{Binding TestResults}" 
                      AutoGenerateColumns="False" 
                      CanUserAddRows="False" 
                      Background="Transparent" 
                      BorderThickness="0" 
                      RowBackground="#1B1E26" 
                      AlternatingRowBackground="#20242D" 
                      Foreground="White" 
                      GridLinesVisibility="Horizontal" 
                      HorizontalGridLinesBrush="#2B303C" 
                      HeadersVisibility="Column" 
                      RowHeaderWidth="0" 
                      IsReadOnly="True">
                
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#252A36" />
                        <Setter Property="Foreground" Value="#A0AAB2" />
                        <Setter Property="FontWeight" Value="Bold" />
                        <Setter Property="Height" Value="36" />
                        <Setter Property="Padding" Value="10,0,10,0" />
                        <Setter Property="BorderThickness" Value="0" />
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Height" Value="32" />
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A313E" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="电机条码" Binding="{Binding Barcode}" Width="200"/>
                    <DataGridTextColumn Header="检测时间" Binding="{Binding TestTime, StringFormat=\{0:yyyy-MM-dd HH:mm:ss\}}" Width="150"/>
                    
                    <!-- Final Result styled -->
                    <DataGridTemplateColumn Header="最终结果" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="3" Padding="6,2,6,2" HorizontalAlignment="Left"
                                        Background="{Binding FinalResult, Converter={StaticResource ResultToBrushConverter}}">
                                    <TextBlock Text="{Binding FinalResult}" Foreground="Black" FontWeight="Bold" FontSize="11"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="空载电流(A)" Binding="{Binding NoLoadCurrent, TargetNullValue='未测'}" Width="90"/>
                    <DataGridTextColumn Header="空载转速" Binding="{Binding NoLoadSpeed, TargetNullValue='未测'}" Width="80"/>
                    <DataGridTextColumn Header="轴伸长度(mm)" Binding="{Binding ShaftLength, TargetNullValue='未测'}" Width="100"/>
                    <DataGridTextColumn Header="滚花直径(mm)" Binding="{Binding KnurlDiameter, TargetNullValue='未测'}" Width="100"/>
                    <DataGridTextColumn Header="正转噪音(dB)" Binding="{Binding FwdNoise, TargetNullValue='未测'}" Width="90"/>
                    <DataGridTextColumn Header="反转噪音(dB)" Binding="{Binding RevNoise, TargetNullValue='未测'}" Width="90"/>
                    <DataGridTextColumn Header="噪音差(dB)" Binding="{Binding NoiseDiff, TargetNullValue='未测'}" Width="95"/>
                    <DataGridTextColumn Header="负载电流(A)" Binding="{Binding LoadCurrent, TargetNullValue='未测'}" Width="90"/>
                    <DataGridTextColumn Header="负载转速" Binding="{Binding LoadSpeed, TargetNullValue='未测'}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- BOTTOM BUTTON BAR -->
        <Grid Grid.Row="3" Margin="20,0,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding TestResults.Count, StringFormat={}共查询到 {0} 条测试数据}" Foreground="#A0AAB2" FontSize="12" VerticalAlignment="Center"/>
            <Button Grid.Column="1" 
                    Content="导出至 Excel (CSV)" 
                    Command="{Binding ExportCommand}" 
                    Width="150" Height="32" 
                    Background="#00FFB2" Foreground="Black" 
                    FontWeight="Bold" BorderThickness="0"/>
        </Grid>
    </Grid>
</UserControl>
