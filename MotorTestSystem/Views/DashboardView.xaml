<UserControl x:Class="MotorTestSystem.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MotorTestSystem.Views"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:conv="clr-namespace:MotorTestSystem.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">
    
    <UserControl.Resources>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
    </UserControl.Resources>
    <Grid Background="#12141A">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>

        <!-- TITLE / HEADER -->
        <TextBlock Text="生产监控数据看板" 
                   Foreground="White" 
                   FontSize="22" 
                   FontWeight="Bold" 
                   Margin="20,15,20,10" 
                   Grid.Row="0"/>

        <!-- STATS CARDS -->
        <Grid Grid.Row="1" Margin="20,5,20,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Card 1: Total Tested -->
            <Border Grid.Column="0" Background="#1B1E26" BorderBrush="#2B303C" BorderThickness="1" CornerRadius="8" Margin="0,0,10,0">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="总测试数 (pcs)" Foreground="#A0AAB2" FontSize="13" VerticalAlignment="Top"/>
                    <TextBlock Grid.Row="1" Text="{Binding TotalChecked}" Foreground="White" FontSize="32" FontWeight="Bold" VerticalAlignment="Bottom" Margin="0,10,0,0"/>
                </Grid>
            </Border>

            <!-- Card 2: OK Count -->
            <Border Grid.Column="1" Background="#1B1E26" BorderBrush="#00FFB2" BorderThickness="0,0,0,3" CornerRadius="8" Margin="10,0,10,0">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="合格数 (OK)" Foreground="#A0AAB2" FontSize="13"/>
                    <TextBlock Grid.Row="1" Text="{Binding OkCount}" Foreground="#00FFB2" FontSize="32" FontWeight="Bold" VerticalAlignment="Bottom" Margin="0,10,0,0"/>
                </Grid>
            </Border>

            <!-- Card 3: NG Count -->
            <Border Grid.Column="2" Background="#1B1E26" BorderBrush="#FF3366" BorderThickness="0,0,0,3" CornerRadius="8" Margin="10,0,10,0">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="不合格数 (NG)" Foreground="#A0AAB2" FontSize="13"/>
                    <TextBlock Grid.Row="1" Text="{Binding NgCount}" Foreground="#FF3366" FontSize="32" FontWeight="Bold" VerticalAlignment="Bottom" Margin="0,10,0,0"/>
                </Grid>
            </Border>

            <!-- Card 4: Pass Rate -->
            <Border Grid.Column="3" Background="#1B1E26" BorderBrush="#00DFFF" BorderThickness="0,0,0,3" CornerRadius="8" Margin="10,0,0,0">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="一次性合格率" Foreground="#A0AAB2" FontSize="13"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,10,0,0">
                        <TextBlock Text="{Binding PassRate, StringFormat={}{0:F2}}" Foreground="#00DFFF" FontSize="32" FontWeight="Bold"/>
                        <TextBlock Text="%" Foreground="#00DFFF" FontSize="16" VerticalAlignment="Bottom" Margin="3,0,0,5" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- MAIN LAYOUT: CHARTS + VIDEO -->
        <Grid Grid.Row="2" Margin="20,0,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6*"/>
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>

            <!-- Charts Container -->
            <Border Grid.Column="0" Background="#1B1E26" BorderBrush="#2B303C" BorderThickness="1" CornerRadius="8" Margin="0,0,10,0" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="1*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="生产统计趋势" Foreground="White" FontSize="15" FontWeight="Bold" Margin="0,0,0,10"/>
                    
                    <!-- Chart 1: Daily Production (Column) -->
                    <Grid Grid.Row="1" Margin="0,5,0,5">
                        <lvc:CartesianChart Series="{Binding OutputSeries}" XAxes="{Binding XAxes}" YAxes="{Binding YAxes}" TooltipFindingStrategy="CompareAllTakeClosest"/>
                    </Grid>

                    <!-- Chart 2: Pass Rate (Line) -->
                    <Grid Grid.Row="2" Margin="0,5,0,5">
                        <lvc:CartesianChart Series="{Binding PassRateSeries}" XAxes="{Binding XAxes}" YAxes="{Binding YAxes}"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Video Camera Container (Hikvision SDK Integration Area) -->
            <Border Grid.Column="1" Background="#1B1E26" BorderBrush="#2B303C" BorderThickness="1" CornerRadius="8" Margin="10,0,0,0" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="#FF3366" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="视频监控集成 (海康威视 SDK)" Foreground="White" FontSize="15" FontWeight="Bold"/>
                    </StackPanel>

                    <!-- Mock Player Area -->
                    <Border Grid.Row="1" Background="Black" CornerRadius="4" BorderBrush="#2B303C" BorderThickness="1">
                        <Grid>
                            <!-- Simulation Video Content -->
                            <Grid Visibility="{Binding IsCameraPlaying, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <!-- Grid lines overlay (representing camera overlay) -->
                                <UniformGrid Rows="4" Columns="4" Opacity="0.15">
                                    <Border BorderBrush="#CCCCCC" BorderThickness="0.5"/>
                                    <Border BorderBrush="#CCCCCC" BorderThickness="0.5"/>
                                    <Border BorderBrush="#CCCCCC" BorderThickness="0.5"/>
                                    <Border BorderBrush="#CCCCCC" BorderThickness="0.5"/>
                                    <Border BorderBrush="#CCCCCC" BorderThickness="0.5"/>
                                    <Border BorderBrush="#CCCCCC" BorderThickness="0.5"/>
                                    <Border BorderBrush="#CCCCCC" BorderThickness="0.5"/>
                                    <Border BorderBrush="#CCCCCC" BorderThickness="0.5"/>
                                    <Border BorderBrush="#CCCCCC" BorderThickness="0.5"/>
                                    <Border BorderBrush="#CCCCCC" BorderThickness="0.5"/>
                                    <Border BorderBrush="#CCCCCC" BorderThickness="0.5"/>
                                    <Border BorderBrush="#CCCCCC" BorderThickness="0.5"/>
                                </UniformGrid>
                                
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <!-- Play camera icon / status -->
                                    <Path Data="M 12 2 C 6.48 2 2 6.48 2 12 C 2 17.52 6.48 22 12 22 C 17.52 22 22 17.52 22 12 C 22 6.48 17.52 2 12 2 Z M 16 13 L 10 17 L 10 7 L 16 12 L 16 13 Z"
                                          Fill="#00FFB2" Width="40" Height="40" Stretch="Fill" HorizontalAlignment="Center" Opacity="0.7"/>
                                    <TextBlock Text="[LIVE] 生产车间 01 通道" Foreground="#00FFB2" FontSize="12" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                                </StackPanel>

                                <!-- Time Stamp Overlay -->
                                <TextBlock Text="REC ● 192.168.1.200" Foreground="White" FontSize="10" Margin="10" VerticalAlignment="Top" HorizontalAlignment="Left" FontFamily="Courier New"/>
                            </Grid>

                            <!-- Stopped state -->
                            <Grid Visibility="{Binding IsCameraPlaying, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                <TextBlock Text="监控已暂停" Foreground="#A0AAB2" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Camera Control Button -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <TextBlock Text="{Binding CameraStatus}" Foreground="#A0AAB2" FontSize="12" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <Button Content="播放/暂停" 
                                Command="{Binding ToggleCameraCommand}"
                                Width="80" Height="28" 
                                Background="#00DFFF" Foreground="Black" 
                                FontWeight="Bold" BorderThickness="0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
