<UserControl x:Class="MotorTestSystem.Views.MonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MotorTestSystem.Views"
             xmlns:conv="clr-namespace:MotorTestSystem.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">

    <UserControl.Resources>
        <conv:StatusToColorConverter x:Key="StatusToColorConverter"/>
        <conv:StatusToTextConverter x:Key="StatusToTextConverter"/>
        <conv:ResultToBrushConverter x:Key="ResultToBrushConverter"/>
        <conv:OnlineToBrushConverter x:Key="OnlineToBrushConverter"/>
    </UserControl.Resources>

    <Grid Background="#12141A">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Margin="20,15,20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="工位实时监视 (3阶段)" Foreground="White" FontSize="22" FontWeight="Bold"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="8" Height="8" Fill="#00FFB2" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBlock Text="正常运行" Foreground="#A0AAB2" FontSize="12" Margin="0,0,15,0"/>
                <Ellipse Width="8" Height="8" Fill="#FFB800" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBlock Text="设备待机" Foreground="#A0AAB2" FontSize="12" Margin="0,0,15,0"/>
                <Ellipse Width="8" Height="8" Fill="#FF3366" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBlock Text="设备故障" Foreground="#A0AAB2" FontSize="12"/>
            </StackPanel>
        </Grid>

        <!-- BENTO 3-COLUMN LAYOUT -->
        <Grid Grid.Row="1" Margin="10,0,10,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Column 1: 空载测试阶段 -->
            <Grid Grid.Column="0" Margin="10,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="阶段 1：空载测试" Foreground="#00DFFF" FontSize="15" FontWeight="Bold" Margin="10,5,0,10"/>
                
                <ItemsControl Grid.Row="1" ItemsSource="{Binding NoLoadStations}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Station Card -->
                            <Border Background="#1B1E26" BorderBrush="#2B303C" BorderThickness="1" CornerRadius="8" Margin="0,0,0,15" Padding="15">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Top Meta Info -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" Foreground="White" FontSize="16" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding PlcModel}" Foreground="#A0AAB2" FontSize="11" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        
                                        <!-- Status Dot and Label -->
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                            <Ellipse Width="8" Height="8" Fill="{Binding Status, Converter={StaticResource StatusToColorConverter}}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Status, Converter={StaticResource StatusToTextConverter}}" Foreground="White" FontSize="12" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Grid>

                                    <Separator Grid.Row="1" Background="#2B303C" Margin="0,10,0,10"/>

                                    <!-- Realtime Parameters Grid -->
                                    <Grid Grid.Row="2" Margin="0,5,0,10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Parameter: Current -->
                                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                                            <TextBlock Text="空载电流" Foreground="#A0AAB2" FontSize="11"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="{Binding NoLoadCurrent, StringFormat={}{0:F3}}" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                                <TextBlock Text=" A" Foreground="#A0AAB2" FontSize="12" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Parameter: Speed -->
                                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                                            <TextBlock Text="空载转速" Foreground="#A0AAB2" FontSize="11"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="{Binding NoLoadSpeed}" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                                <TextBlock Text=" r/min" Foreground="#A0AAB2" FontSize="12" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Parameter: Shaft Length -->
                                        <StackPanel Grid.Row="1" Grid.Column="0">
                                            <TextBlock Text="轴伸长度" Foreground="#A0AAB2" FontSize="11"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="{Binding ShaftLength, StringFormat={}{0:F3}}" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                                <TextBlock Text=" mm" Foreground="#A0AAB2" FontSize="12" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Parameter: Knurl Diameter -->
                                        <StackPanel Grid.Row="1" Grid.Column="1">
                                            <TextBlock Text="滚花直径" Foreground="#A0AAB2" FontSize="11"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="{Binding KnurlDiameter, StringFormat={}{0:F3}}" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                                <TextBlock Text=" mm" Foreground="#A0AAB2" FontSize="12" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Bottom Info (Barcode & Result) -->
                                    <Border Grid.Row="3" Background="#12141A" CornerRadius="4" Padding="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="当前电机条码" Foreground="#A0AAB2" FontSize="10"/>
                                                <TextBlock Text="{Binding Barcode}" Foreground="White" FontSize="12" FontWeight="Bold" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            
                                            <!-- Result Badge -->
                                            <Border Grid.Column="1" Background="{Binding Result, Converter={StaticResource ResultToBrushConverter}}" CornerRadius="3" Padding="8,4,8,4" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Result}" Foreground="Black" FontSize="12" FontWeight="Bold"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

            <!-- Column 2: 噪音测试阶段 -->
            <Grid Grid.Column="1" Margin="10,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="阶段 2：噪音测试" Foreground="#00DFFF" FontSize="15" FontWeight="Bold" Margin="10,5,0,10"/>

                <ItemsControl Grid.Row="1" ItemsSource="{Binding NoiseStations}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Station Card -->
                            <Border Background="#1B1E26" BorderBrush="#2B303C" BorderThickness="1" CornerRadius="8" Margin="0,0,0,15" Padding="15">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Top Meta Info -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" Foreground="White" FontSize="16" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding PlcModel}" Foreground="#A0AAB2" FontSize="11" Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <!-- Status Dot and Label -->
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                            <Ellipse Width="8" Height="8" Fill="{Binding Status, Converter={StaticResource StatusToColorConverter}}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Status, Converter={StaticResource StatusToTextConverter}}" Foreground="White" FontSize="12" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Grid>

                                    <Separator Grid.Row="1" Background="#2B303C" Margin="0,10,0,10"/>

                                    <!-- Realtime Parameters Grid -->
                                    <Grid Grid.Row="2" Margin="0,5,0,10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Parameter: Forward Noise -->
                                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                                            <TextBlock Text="正转噪音" Foreground="#A0AAB2" FontSize="11"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="{Binding FwdNoise, StringFormat={}{0:F1}}" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                                <TextBlock Text=" dB" Foreground="#A0AAB2" FontSize="12" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Parameter: Reverse Noise -->
                                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                                            <TextBlock Text="反转噪音" Foreground="#A0AAB2" FontSize="11"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="{Binding RevNoise, StringFormat={}{0:F1}}" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                                <TextBlock Text=" dB" Foreground="#A0AAB2" FontSize="12" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Parameter: Noise Diff -->
                                        <StackPanel Grid.Row="1" Grid.Column="0">
                                            <TextBlock Text="噪音差值" Foreground="#A0AAB2" FontSize="11"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="{Binding NoiseDiff, StringFormat={}{0:F1}}" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                                <TextBlock Text=" dB" Foreground="#A0AAB2" FontSize="12" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Bottom Info (Barcode & Result) -->
                                    <Border Grid.Row="3" Background="#12141A" CornerRadius="4" Padding="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="当前电机条码" Foreground="#A0AAB2" FontSize="10"/>
                                                <TextBlock Text="{Binding Barcode}" Foreground="White" FontSize="12" FontWeight="Bold" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <!-- Result Badge -->
                                            <Border Grid.Column="1" Background="{Binding Result, Converter={StaticResource ResultToBrushConverter}}" CornerRadius="3" Padding="8,4,8,4" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Result}" Foreground="Black" FontSize="12" FontWeight="Bold"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

            <!-- Column 3: 负载测试阶段 -->
            <Grid Grid.Column="2" Margin="10,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="阶段 3：负载测试" Foreground="#00DFFF" FontSize="15" FontWeight="Bold" Margin="10,5,0,10"/>

                <ItemsControl Grid.Row="1" ItemsSource="{Binding LoadStations}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Station Card -->
                            <Border Background="#1B1E26" BorderBrush="#2B303C" BorderThickness="1" CornerRadius="8" Margin="0,0,0,15" Padding="15">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Top Meta Info -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" Foreground="White" FontSize="16" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding PlcModel}" Foreground="#A0AAB2" FontSize="11" Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <!-- Status Dot and Label -->
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                            <Ellipse Width="8" Height="8" Fill="{Binding Status, Converter={StaticResource StatusToColorConverter}}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Status, Converter={StaticResource StatusToTextConverter}}" Foreground="White" FontSize="12" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Grid>

                                    <Separator Grid.Row="1" Background="#2B303C" Margin="0,10,0,10"/>

                                    <!-- Realtime Parameters Grid -->
                                    <Grid Grid.Row="2" Margin="0,5,0,10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Parameter: Load Current -->
                                        <StackPanel Grid.Row="0" Grid.Column="0">
                                            <TextBlock Text="负载电流" Foreground="#A0AAB2" FontSize="11"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="{Binding LoadCurrent, StringFormat={}{0:F3}}" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                                <TextBlock Text=" A" Foreground="#A0AAB2" FontSize="12" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Parameter: Load Speed -->
                                        <StackPanel Grid.Row="0" Grid.Column="1">
                                            <TextBlock Text="负载转速" Foreground="#A0AAB2" FontSize="11"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="{Binding LoadSpeed}" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                                <TextBlock Text=" r/min" Foreground="#A0AAB2" FontSize="12" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Bottom Info (Barcode & Result) -->
                                    <Border Grid.Row="3" Background="#12141A" CornerRadius="4" Padding="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="当前电机条码" Foreground="#A0AAB2" FontSize="10"/>
                                                <TextBlock Text="{Binding Barcode}" Foreground="White" FontSize="12" FontWeight="Bold" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <!-- Result Badge -->
                                            <Border Grid.Column="1" Background="{Binding Result, Converter={StaticResource ResultToBrushConverter}}" CornerRadius="3" Padding="8,4,8,4" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Result}" Foreground="Black" FontSize="12" FontWeight="Bold"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
