<UserControl x:Class="MotorTestSystem.Views.ConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MotorTestSystem.Views"
             xmlns:conv="clr-namespace:MotorTestSystem.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">

    <UserControl.Resources>
        <conv:OnlineToBrushConverter x:Key="OnlineToBrushConverter"/>
    </UserControl.Resources>

    <Grid Background="#12141A">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE -->
        <TextBlock Text="通信管理与参数配置" Foreground="White" FontSize="22" FontWeight="Bold" Margin="20,15,20,10"/>

        <!-- STATIONS CONFIG GRID -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="10,0,10,20">
            <ItemsControl ItemsSource="{Binding Stations}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2" Margin="5"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#1B1E26" BorderBrush="#2B303C" BorderThickness="1" CornerRadius="8" Margin="10" Padding="15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Header: Station Name & Status -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" Foreground="White" FontSize="15" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding PlcModel}" Foreground="#A0AAB2" FontSize="11" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    
                                    <!-- Online Indicator -->
                                    <Border Grid.Column="1" Background="{Binding IsConnected, Converter={StaticResource OnlineToBrushConverter}}" CornerRadius="3" Padding="8,4,8,4" VerticalAlignment="Center">
                                        <TextBlock Foreground="Black" FontSize="11" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                            <Setter Property="Text" Value="已连接" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                                            <Setter Property="Text" Value="未连接" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </Grid>

                                <Separator Grid.Row="1" Background="#2B303C" Margin="0,12,0,12"/>

                                <!-- Config Fields Grid -->
                                <Grid Grid.Row="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- IP Address -->
                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,12">
                                        <TextBlock Text="IP 地址" Foreground="#A0AAB2" FontSize="11" Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}" 
                                                 Background="#12141A" Foreground="White" BorderBrush="#2B303C" Height="28" Padding="5,0,0,0" VerticalContentAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Port -->
                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,12">
                                        <TextBlock Text="端口号" Foreground="#A0AAB2" FontSize="11" Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" 
                                                 Background="#12141A" Foreground="White" BorderBrush="#2B303C" Height="28" Padding="5,0,0,0" VerticalContentAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Protocol -->
                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,12">
                                        <TextBlock Text="通信协议" Foreground="#A0AAB2" FontSize="11" Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding Protocol}" IsReadOnly="True"
                                                 Background="#1C1F28" Foreground="#A0AAB2" BorderBrush="#2B303C" Height="28" Padding="5,0,0,0" VerticalContentAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Station ID -->
                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,12">
                                        <TextBlock Text="通信站号 (Device ID)" Foreground="#A0AAB2" FontSize="11" Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding StationId, UpdateSourceTrigger=PropertyChanged}" 
                                                 Background="#12141A" Foreground="White" BorderBrush="#2B303C" Height="28" Padding="5,0,0,0" VerticalContentAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Test Connection Button -->
                                    <Button Grid.Row="2" Grid.Column="1" 
                                            Content="测试连接" 
                                            Command="{Binding DataContext.TestConnectionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Height="28" Margin="10,5,0,0"
                                            Background="#00DFFF" Foreground="Black" 
                                            FontWeight="Bold" BorderThickness="0"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
