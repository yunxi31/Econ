<UserControl x:Class="MotorTestSystem.Views.ConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MotorTestSystem.Views"
             xmlns:root="clr-namespace:MotorTestSystem"
             xmlns:conv="clr-namespace:MotorTestSystem.Converters"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000">
  <UserControl.Resources>
    <ResourceDictionary>
      <Style x:Key="PremiumTextBoxStyle" TargetType="{x:Type TextBox}">
        <Setter Property="Background" Value="#0F1418" />
        <Setter Property="Foreground" Value="#E1E6EB" />
        <Setter Property="BorderBrush" Value="#252F38" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type TextBox}">
              <Border Name="border" Background="{TemplateBinding Control.Background}" BorderBrush="{TemplateBinding Control.BorderBrush}" BorderThickness="{TemplateBinding Control.BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Control.Padding}">
                <ScrollViewer Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="UIElement.IsMouseOver" Value="true">
                  <Setter TargetName="border" Property="Border.BorderBrush" Value="#12DDF7" />
                </Trigger>
                <Trigger Property="UIElement.IsFocused" Value="true">
                  <Setter TargetName="border" Property="Border.BorderBrush" Value="#12DDF7" />
                  <Setter TargetName="border" Property="Border.BorderThickness" Value="1" />
                </Trigger>
                <Trigger Property="TextBoxBase.IsReadOnly" Value="true">
                  <Setter Property="Background" Value="#14191E" />
                  <Setter Property="Foreground" Value="#8E9CA8" />
                  <Setter Property="BorderBrush" Value="#1F2830" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
      <Style x:Key="PlcTextBoxStyle" TargetType="{x:Type TextBox}" BasedOn="{StaticResource PremiumTextBoxStyle}">
        <Style.Triggers>
          <MultiDataTrigger>
            <MultiDataTrigger.Conditions>
              <Condition Value="在线" Binding="{Binding Path=Status}" />
              <Condition Value="S7-1200" Binding="{Binding Path=PlcModel}" />
            </MultiDataTrigger.Conditions>
            <Setter Property="Foreground" Value="#12DDF7" />
          </MultiDataTrigger>
          <MultiDataTrigger>
            <MultiDataTrigger.Conditions>
              <Condition Value="在线" Binding="{Binding Path=Status}" />
              <Condition Value="S7-1500" Binding="{Binding Path=PlcModel}" />
            </MultiDataTrigger.Conditions>
            <Setter Property="Foreground" Value="#12DDF7" />
          </MultiDataTrigger>
          <MultiDataTrigger>
            <MultiDataTrigger.Conditions>
              <Condition Value="在线" Binding="{Binding Path=Status}" />
              <Condition Value="AM600" Binding="{Binding Path=PlcModel}" />
            </MultiDataTrigger.Conditions>
            <Setter Property="Foreground" Value="#12DDF7" />
          </MultiDataTrigger>
          <MultiDataTrigger>
            <MultiDataTrigger.Conditions>
              <Condition Value="在线" Binding="{Binding Path=Status}" />
              <Condition Value="FX5U" Binding="{Binding Path=PlcModel}" />
            </MultiDataTrigger.Conditions>
            <Setter Property="Foreground" Value="#10B981" />
          </MultiDataTrigger>
        </Style.Triggers>
      </Style>
      <Style x:Key="LogListBoxStyle" TargetType="{x:Type ListBox}">
        <Setter Property="Background" Value="#0F1418" />
        <Setter Property="BorderBrush" Value="#1F2830" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="ItemContainerStyle">
          <Setter.Value>
            <Style TargetType="{x:Type ListBoxItem}">
              <Setter Property="Background" Value="#00FFFFFF" />
              <Setter Property="BorderBrush" Value="#172027" />
              <Setter Property="BorderThickness" Value="0,0,0,1" />
              <Setter Property="Padding" Value="12,6" />
              <Setter Property="Focusable" Value="False" />
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="{x:Type ListBoxItem}">
                    <Border Background="{TemplateBinding Control.Background}" BorderBrush="{TemplateBinding Control.BorderBrush}" BorderThickness="{TemplateBinding Control.BorderThickness}" Padding="{TemplateBinding Control.Padding}">
                      <ContentPresenter />
                    </Border>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </Setter.Value>
        </Setter>
      </Style>
    </ResourceDictionary>
  </UserControl.Resources>
  <Grid Background="#10161B">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Grid Row="0" Margin="24,20,24,15">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0">
        <TextBlock Text="{root:Loc 通信与系统配置}" Foreground="#FFFFFFFF" FontSize="22" FontWeight="Bold" />
        <TextBlock Text="{root:Loc PLC 节点拓扑与通信设置}" Foreground="#8E9CA8" FontSize="12" Margin="0,4,0,0" />
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
        <Button CommandParameter="Monitor" Margin="0,0,12,0" Height="36" Padding="16,0" Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}">
          <FrameworkElement.Style>
            <Style TargetType="{x:Type Button}">
              <Setter Property="Background" Value="#00FFFFFF" />
              <Setter Property="BorderBrush" Value="#2F3B43" />
              <Setter Property="BorderThickness" Value="1" />
              <Setter Property="Foreground" Value="#8E9CA8" />
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="{x:Type Button}">
                    <Border Background="{TemplateBinding Control.Background}" BorderBrush="{TemplateBinding Control.BorderBrush}" BorderThickness="{TemplateBinding Control.BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Control.Padding}">
                      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Data="M10,20 L10,12 L14,12 L14,20 L19,20 L19,10 L12,3 L5,10 L5,20" Fill="{TemplateBinding Control.Foreground}" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="{root:Loc 返回主页}" Foreground="{TemplateBinding Control.Foreground}" VerticalAlignment="Center" FontWeight="SemiBold" />
                      </StackPanel>
                    </Border>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
              <Style.Triggers>
                <Trigger Property="UIElement.IsMouseOver" Value="True">
                  <Setter Property="BorderBrush" Value="#12DDF7" />
                  <Setter Property="Foreground" Value="#FFFFFFFF" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter Property="Background" Value="#1512DDF7" />
                  <Setter Property="BorderBrush" Value="#12DDF7" />
                </Trigger>
              </Style.Triggers>
            </Style>
          </FrameworkElement.Style>
        </Button>
        <Button Height="36" Padding="16,0" Command="{Binding SaveAllCommand}">
          <FrameworkElement.Style>
            <Style TargetType="{x:Type Button}">
              <Setter Property="Background" Value="#12DDF7" />
              <Setter Property="Foreground" Value="#FF000000" />
              <Setter Property="BorderThickness" Value="0" />
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="{x:Type Button}">
                    <Border Background="{TemplateBinding Control.Background}" CornerRadius="4" Padding="{TemplateBinding Control.Padding}">
                      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Data="M19,20 L5,20 L5,4 L15,4 L19,8 M12,18 A4,4 0 1 0 12,10A4,4 0 0 0 12,18M6,6 L13,6 L13,9 L6,9" Fill="#FF000000" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="{root:Loc 保存所有配置}" VerticalAlignment="Center" FontWeight="Bold" />
                      </StackPanel>
                    </Border>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
              <Style.Triggers>
                <Trigger Property="UIElement.IsMouseOver" Value="True">
                  <Setter Property="Background" Value="#33E2FF" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter Property="Background" Value="#00C4DF" />
                </Trigger>
              </Style.Triggers>
            </Style>
          </FrameworkElement.Style>
        </Button>
      </StackPanel>
    </Grid>
    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="16,0,16,10">
      <ItemsControl ItemsSource="{Binding Stations}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <UniformGrid Columns="3" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Margin="8" Background="#151C22" BorderBrush="#252F38" BorderThickness="1" CornerRadius="6" SnapsToDevicePixels="True">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                
                <!-- 任务一：重构卡片的状态边框 (左侧高亮条) -->
                <Border Grid.Column="0" Width="4" CornerRadius="5,0,0,5" SnapsToDevicePixels="True">
                  <Border.Style>
                    <Style TargetType="{x:Type Border}">
                      <Setter Property="Background" Value="#5E6E7A" />
                      <Style.Triggers>
                        <DataTrigger Value="故障" Binding="{Binding Status}">
                          <Setter Property="Background" Value="#EF4444" />
                        </DataTrigger>
                        <DataTrigger Value="离线" Binding="{Binding Status}">
                          <Setter Property="Background" Value="#5E6E7A" />
                        </DataTrigger>
                        <MultiDataTrigger>
                          <MultiDataTrigger.Conditions>
                            <Condition Value="在线" Binding="{Binding Path=Status}" />
                            <Condition Value="FX5U" Binding="{Binding Path=PlcModel}" />
                          </MultiDataTrigger.Conditions>
                          <Setter Property="Background" Value="#10B981" />
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                          <MultiDataTrigger.Conditions>
                            <Condition Value="在线" Binding="{Binding Path=Status}" />
                            <Condition Value="S7-1200" Binding="{Binding Path=PlcModel}" />
                          </MultiDataTrigger.Conditions>
                          <Setter Property="Background" Value="#12DDF7" />
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                          <MultiDataTrigger.Conditions>
                            <Condition Value="在线" Binding="{Binding Path=Status}" />
                            <Condition Value="S7-1500" Binding="{Binding Path=PlcModel}" />
                          </MultiDataTrigger.Conditions>
                          <Setter Property="Background" Value="#12DDF7" />
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                          <MultiDataTrigger.Conditions>
                            <Condition Value="在线" Binding="{Binding Path=Status}" />
                            <Condition Value="AM600" Binding="{Binding Path=PlcModel}" />
                          </MultiDataTrigger.Conditions>
                          <Setter Property="Background" Value="#12DDF7" />
                        </MultiDataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>
                </Border>
                
                <!-- 右侧主体内容 (包含 Margins/Paddings 的精细微调) -->
                <Grid Grid.Column="1" Margin="18">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  <Grid Row="0">
                    <Grid.ColumnDefinitions>
                       <ColumnDefinition Width="Auto" />
                       <ColumnDefinition Width="*" />
                       <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="26" Height="26" Margin="0,0,10,0" BorderBrush="#12DDF7" BorderThickness="1.5" CornerRadius="2" Background="#0F171C">
                      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Stretch">
                        <Border Width="1.5" Margin="1,2" Background="#12DDF7" Opacity="0.8" />
                        <Border Width="1.5" Margin="1,2" Background="#12DDF7" Opacity="0.8" />
                        <Border Width="1.5" Margin="1,2" Background="#12DDF7" Opacity="0.8" />
                      </StackPanel>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                      <TextBlock Foreground="#FFFFFFFF" FontSize="16" FontWeight="Bold" Text="{Binding Name}" />
                      <TextBlock Foreground="#8E9CA8" FontSize="11" Margin="0,2,0,0" Text="{Binding PlcModel}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                      <Border Width="6" Height="6" CornerRadius="3" Margin="0,0,6,0" VerticalAlignment="Center">
                        <FrameworkElement.Style>
                          <Style TargetType="{x:Type Border}">
                            <Style.Triggers>
                              <DataTrigger Value="在线" Binding="{Binding Status}">
                                <Setter Property="Background" Value="#10B981" />
                              </DataTrigger>
                              <DataTrigger Value="故障" Binding="{Binding Status}">
                                <Setter Property="Background" Value="#EF4444" />
                              </DataTrigger>
                              <DataTrigger Value="离线" Binding="{Binding Status}">
                                <Setter Property="Background" Value="#5E6E7A" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </FrameworkElement.Style>
                      </Border>
                      <TextBlock FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center">
                        <TextBlock.Text>
                          <MultiBinding Converter="{StaticResource LocMultiConverter}">
                            <Binding Path="Status" />
                            <Binding Source="{x:Static root:LanguageManager.Instance}" Path="CurrentLanguage" />
                          </MultiBinding>
                        </TextBlock.Text>
                        <FrameworkElement.Style>
                          <Style TargetType="{x:Type TextBlock}">
                            <Style.Triggers>
                              <DataTrigger Value="在线" Binding="{Binding Status}">
                                <Setter Property="Foreground" Value="#10B981" />
                              </DataTrigger>
                              <DataTrigger Value="故障" Binding="{Binding Status}">
                                <Setter Property="Foreground" Value="#EF4444" />
                              </DataTrigger>
                              <DataTrigger Value="离线" Binding="{Binding Status}">
                                <Setter Property="Foreground" Value="#8E9CA8" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </FrameworkElement.Style>
                      </TextBlock>
                    </StackPanel>
                  </Grid>
                  <Border Grid.Row="1" Height="1" Background="#242F38" Margin="0,12" />
                  
                  <!-- 任务三：精修卡片内部布局 (IP/端口两栏 & 协议/站号两栏) -->
                  <Grid Grid.Row="2" Margin="0,0,0,14">
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                        <!-- IP 地址 -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,12">
                      <TextBlock Text="{root:Loc IP 地址}" Foreground="#8E9CA8" FontSize="11" Margin="0,0,0,4" />
                      <TextBox Style="{StaticResource PlcTextBoxStyle}" Text="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    
                    <!-- 端口 -->
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,12">
                      <TextBlock Text="{root:Loc 端口}" Foreground="#8E9CA8" FontSize="11" Margin="0,0,0,4" />
                      <TextBox Style="{StaticResource PlcTextBoxStyle}" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    
                    <!-- 协议 -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,0">
                      <TextBlock Text="{root:Loc 协议}" Foreground="#8E9CA8" FontSize="11" Margin="0,0,0,4" />
                      <TextBox IsReadOnly="True" Style="{StaticResource PremiumTextBoxStyle}" Text="{Binding Protocol}" />
                    </StackPanel>
                    
                    <!-- 站号 -->
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,0">
                      <TextBlock Text="{root:Loc 站号}" Foreground="#8E9CA8" FontSize="11" Margin="0,0,0,4" />
                      <TextBox Style="{StaticResource PremiumTextBoxStyle}" Text="{Binding StationId, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                  </Grid>
                  
                  <Button Grid.Row="3" Height="32" FontWeight="Bold" Command="{Binding DataContext.TestConnectionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}">
                    <FrameworkElement.Style>
                      <Style TargetType="{x:Type Button}">
                        <Setter Property="Content" Value="{root:Loc 测试连接}" />
                        <Setter Property="Background" Value="#00FFFFFF" />
                        <Setter Property="Foreground" Value="#12DDF7" />
                        <Setter Property="BorderBrush" Value="#12DDF7" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="Template">
                          <Setter.Value>
                            <ControlTemplate TargetType="{x:Type Button}">
                              <Border Background="{TemplateBinding Control.Background}" BorderBrush="{TemplateBinding Control.BorderBrush}" BorderThickness="{TemplateBinding Control.BorderThickness}" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                              </Border>
                            </ControlTemplate>
                          </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                          <Trigger Property="UIElement.IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#1A12DDF7" />
                          </Trigger>
                          <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#3312DDF7" />
                          </Trigger>
                          <DataTrigger Value="故障" Binding="{Binding Status}">
                            <Setter Property="Content" Value="{root:Loc 重试连接}" />
                            <Setter Property="Background" Value="#C92A2A" />
                            <Setter Property="Foreground" Value="#FFFFFFFF" />
                            <Setter Property="BorderThickness" Value="0" />
                          </DataTrigger>
                          <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                              <Condition Value="故障" Binding="{Binding Path=Status}" />
                              <Condition Value="True" Binding="{Binding Path=IsMouseOver, RelativeSource={RelativeSource Self}}" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Background" Value="#E03131" />
                          </MultiDataTrigger>
                        </Style.Triggers>
                      </Style>
                    </FrameworkElement.Style>
                  </Button>
                </Grid>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
    <Border Grid.Row="2" Background="#151D24" BorderBrush="#242F38" BorderThickness="0,1,0,0" SnapsToDevicePixels="True">
      <Grid Margin="24,16,24,16">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Row="0">
          <Grid.Style>
            <Style TargetType="{x:Type Grid}">
              <Setter Property="Margin" Value="0,0,0,12" />
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsChecked, ElementName=LogExpandToggle}" Value="False">
                  <Setter Property="Margin" Value="0" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Grid.Style>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <ToggleButton x:Name="LogExpandToggle" Grid.Column="0" IsChecked="False" Cursor="Hand" VerticalAlignment="Center">
            <ToggleButton.Template>
              <ControlTemplate TargetType="{x:Type ToggleButton}">
                <Border Background="Transparent">
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Path x:Name="ArrowPath" Data="M8.59,16.59 L13.17,12 L8.59,7.41 L10,6 L16,12 L10,18 L8.59,16.59 Z" Fill="#8E9CA8" Width="12" Height="12" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                      <Path.RenderTransform>
                        <RotateTransform Angle="90" />
                      </Path.RenderTransform>
                    </Path>
                    <Path Data="M19,3 L14.82,3 C14.4,1.84 13.3,1 12,1 C10.7,1 9.6,1.8399999999999999 9.18,3 L5,3 C3.9,3 3,3.9 3,5 L3,19 C3,20.1 3.9,21 5,21 L19,21 C20.1,21 21,20.1 21,19 L21,5 C21,3.9 20.1,3 19,3 M12,3 C12.55,3 13,3.45 13,4 C13,4.55 12.55,5 12,5 C11.45,5 11,4.55 11,4 C11,3.45 11.45,3 12,3 M14,17 L7,17 L7,15 L14,15 L14,17 M17,13 L7,13 L7,11 L17,11 L17,13 M17,9 L7,9 L7,7 L17,7 L17,9" Fill="#12DDF7" Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock x:Name="TitleText" Text="{root:Loc 诊断事件日志}" Foreground="#FFFFFFFF" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                    <TextBlock Text="COMMUNICATION EVENT LOGS" Foreground="#4F6270" FontSize="11" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center" />
                  </StackPanel>
                </Border>
                <ControlTemplate.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="TitleText" Property="Foreground" Value="#12DDF7" />
                    <Setter TargetName="ArrowPath" Property="Fill" Value="#12DDF7" />
                  </Trigger>
                  <Trigger Property="IsChecked" Value="False">
                    <Setter TargetName="ArrowPath" Property="RenderTransform">
                      <Setter.Value>
                        <RotateTransform Angle="0" />
                      </Setter.Value>
                    </Setter>
                  </Trigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </ToggleButton.Template>
          </ToggleButton>
          <Button Grid.Column="1" Height="28" Padding="12,0" Command="{Binding ClearLogsCommand}">
            <FrameworkElement.Style>
              <Style TargetType="{x:Type Button}">
                <Setter Property="Background" Value="#00FFFFFF" />
                <Setter Property="BorderBrush" Value="#2F3B43" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Foreground" Value="#8E9CA8" />
                <Setter Property="Template">
                  <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                      <Border Background="{TemplateBinding Control.Background}" BorderBrush="{TemplateBinding Control.BorderBrush}" BorderThickness="{TemplateBinding Control.BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Control.Padding}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                          <Path Data="M6,19 C6,20.1 6.9,21 8,21 L16,21 C17.1,21 18,20.1 18,19 L18,7 L6,7 L6,19 M19,4 L15.5,4 L14.5,3 L9.5,3 L8.5,4 L5,4 L5,6 L19,6 L19,4" Fill="{TemplateBinding Control.Foreground}" Width="12" Height="12" Stretch="Uniform" Margin="0,0,6,0" VerticalAlignment="Center" />
                          <TextBlock Text="{root:Loc 清除日志}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>
                      </Border>
                    </ControlTemplate>
                  </Setter.Value>
                </Setter>
                <Style.Triggers>
                  <Trigger Property="UIElement.IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#EF4444" />
                    <Setter Property="Foreground" Value="#EF4444" />
                  </Trigger>
                  <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1AEF4444" />
                    <Setter Property="BorderBrush" Value="#EF4444" />
                  </Trigger>
                </Style.Triggers>
              </Style>
            </FrameworkElement.Style>
          </Button>
        </Grid>
        <ListBox Grid.Row="1" Grid.IsSharedSizeScope="True" ItemsSource="{Binding DiagnosticLogs}" Height="220">
          <ListBox.Style>
            <Style TargetType="{x:Type ListBox}" BasedOn="{StaticResource LogListBoxStyle}">
              <Setter Property="Visibility" Value="Visible" />
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsChecked, ElementName=LogExpandToggle}" Value="False">
                  <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </ListBox.Style>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" SharedSizeGroup="TimeCol" />
                  <ColumnDefinition Width="Auto" SharedSizeGroup="LevelCol" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Foreground="#8E9CA8" FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,15,0" Text="{Binding Timestamp}" />
                <TextBlock Grid.Column="1" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,15,0" Text="{Binding Level}" Foreground="{Binding LevelBrush}" />
                <TextBlock Grid.Column="2" Foreground="#E1E6EB" VerticalAlignment="Center" TextWrapping="Wrap" Text="{Binding Message}" />
              </Grid>
            </DataTemplate>
