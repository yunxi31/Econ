<UserControl x:Class="MotorTestSystem.Views.NotificationCenterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.expression/blend/2008" 
             xmlns:local="clr-namespace:MotorTestSystem.Views"
             xmlns:vm="clr-namespace:MotorTestSystem.ViewModels"
             xmlns:conv="clr-namespace:MotorTestSystem.Converters"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="760" d:DesignWidth="1080"
             Background="#13141E">

    <UserControl.Resources>
        <!-- Converters -->
        <conv:StringEqualsToBoolConverter x:Key="StringEqualsToBoolConverter"/>

        <!-- Colors -->
        <SolidColorBrush x:Key="BackgroundDark" Color="#13141E"/>
        <SolidColorBrush x:Key="PanelBackground" Color="#212431"/>
        <SolidColorBrush x:Key="AccentCyan" Color="#00D2E6"/>
        <SolidColorBrush x:Key="AccentRed" Color="#F74C5B"/>
        <SolidColorBrush x:Key="AccentWarning" Color="#F39C12"/>
        <SolidColorBrush x:Key="AccentSystem" Color="#5C6070"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8A8D99"/>

        <!-- Header Button Style -->
        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="#1B1C28"/>
            <Setter Property="BorderBrush" Value="#333645"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#8A8D99"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="12,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#252736"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                    <Setter Property="BorderBrush" Value="#45495E"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#151620"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Base Pill RadioButton Style -->
        <Style x:Key="PillRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="#1B1C28"/>
            <Setter Property="BorderBrush" Value="#333645"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#8A8D99"/>
            <Setter Property="GroupName" Value="FilterPills"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="PillBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18"
                                Padding="16,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Icon (if Tag is set) -->
                                <materialDesign:PackIcon x:Name="PillIcon"
                                                         Kind="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                                         Width="16"
                                                         Height="16"
                                                         Margin="0,0,8,0"
                                                         VerticalAlignment="Center"/>
                                <!-- Text / Badge content -->
                                <ContentPresenter x:Name="PillText"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="False"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="{x:Null}">
                                <Setter TargetName="PillIcon" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PillBorder" Property="Background" Value="#252736"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Pill colors on selection -->
        <Style x:Key="AllPillStyle" TargetType="RadioButton" BasedOn="{StaticResource PillRadioButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#00D2E6"/>
                    <Setter Property="BorderBrush" Value="#00D2E6"/>
                    <Setter Property="Foreground" Value="#090E12"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AlarmPillStyle" TargetType="RadioButton" BasedOn="{StaticResource PillRadioButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#F74C5B"/>
                    <Setter Property="BorderBrush" Value="#F74C5B"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MaintenancePillStyle" TargetType="RadioButton" BasedOn="{StaticResource PillRadioButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#F39C12"/>
                    <Setter Property="BorderBrush" Value="#F39C12"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SystemPillStyle" TargetType="RadioButton" BasedOn="{StaticResource PillRadioButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#5C6070"/>
                    <Setter Property="BorderBrush" Value="#5C6070"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ListBoxItem Style to strip selection styles -->
        <Style x:Key="NotificationListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0,0,0,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="38,30,38,30">
        <Grid.RowDefinitions>
            <!-- 1. Header (Title + Buttons) -->
            <RowDefinition Height="Auto"/>
            <!-- Spacer -->
            <RowDefinition Height="24"/>
            <!-- 2. Filters -->
            <RowDefinition Height="Auto"/>
            <!-- Spacer -->
            <RowDefinition Height="20"/>
            <!-- 3. Notification List -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 1. Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Bell icon + Title -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <materialDesign:PackIcon Kind="BellOutline"
                                         Width="28"
                                         Height="28"
                                         Foreground="#FFFFFF"
                                         VerticalAlignment="Center"/>
                <TextBlock Text="通知中心"
                           Foreground="#FFFFFF"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Right: Actions -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource HeaderButtonStyle}" Command="{Binding MarkAllAsReadCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Check" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="全部标记为已读" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource HeaderButtonStyle}" Command="{Binding ClearAllCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="DeleteOutline" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="清空所有" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 2. Filters -->
        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <!-- 全部 Pill -->
            <RadioButton Style="{StaticResource AllPillStyle}"
                         IsChecked="{Binding SelectedFilter, Converter={StaticResource StringEqualsToBoolConverter}, ConverterParameter=全部, Mode=TwoWay}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="全部" VerticalAlignment="Center"/>
                    <Border Margin="8,0,0,0" CornerRadius="9" Padding="6,2" VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#2C303E"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                        <Setter Property="Background" Value="#152A36"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding AllCount}" FontSize="11" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#8A8D99"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                            <Setter Property="Foreground" Value="#00D2E6"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </RadioButton>

            <!-- 报警 Pill -->
            <RadioButton Style="{StaticResource AlarmPillStyle}" Tag="AlertCircleOutline"
                         IsChecked="{Binding SelectedFilter, Converter={StaticResource StringEqualsToBoolConverter}, ConverterParameter=报警, Mode=TwoWay}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="报警" VerticalAlignment="Center"/>
                    <Border Margin="8,0,0,0" CornerRadius="9" Padding="6,2" VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#2C303E"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                        <Setter Property="Background" Value="#4A1519"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding AlarmCount}" FontSize="11" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#8A8D99"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                            <Setter Property="Foreground" Value="#F74C5B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </RadioButton>

            <!-- 维护 Pill -->
            <RadioButton Style="{StaticResource MaintenancePillStyle}" Tag="WrenchOutline"
                         IsChecked="{Binding SelectedFilter, Converter={StaticResource StringEqualsToBoolConverter}, ConverterParameter=维护, Mode=TwoWay}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="维护" VerticalAlignment="Center"/>
                    <Border Margin="8,0,0,0" CornerRadius="9" Padding="6,2" VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#2C303E"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                        <Setter Property="Background" Value="#4A3615"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding MaintenanceCount}" FontSize="11" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#8A8D99"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                            <Setter Property="Foreground" Value="#F39C12"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </RadioButton>

            <!-- 系统 Pill -->
            <RadioButton Style="{StaticResource SystemPillStyle}" Tag="InformationOutline"
                         IsChecked="{Binding SelectedFilter, Converter={StaticResource StringEqualsToBoolConverter}, ConverterParameter=系统, Mode=TwoWay}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="系统" VerticalAlignment="Center"/>
                    <Border Margin="8,0,0,0" CornerRadius="9" Padding="6,2" VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#2C303E"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                        <Setter Property="Background" Value="#2B2D38"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding SystemCount}" FontSize="11" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#8A8D99"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=RadioButton}}" Value="True">
                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </RadioButton>
        </StackPanel>

        <!-- 3. Notification List -->
        <ListBox Grid.Row="4"
                 ItemsSource="{Binding Notifications}"
                 Background="Transparent"
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ItemContainerStyle="{StaticResource NotificationListBoxItemStyle}">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:NotificationItemViewModel}">
                    <Border Background="#212431"
                            BorderBrush="#333645"
                            BorderThickness="1"
                            CornerRadius="8"
                            MinHeight="82"
                            Padding="0,0,0,0">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding DataContext.ToggleReadStatusCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          CommandParameter="{Binding}"/>
                        </Border.InputBindings>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <!-- Left Indicator bar -->
                                <ColumnDefinition Width="4"/>
                                <!-- Icon container -->
                                <ColumnDefinition Width="64"/>
                                <!-- Main Content -->
                                <ColumnDefinition Width="*"/>
                                <!-- Right Timestamp -->
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>

                            <!-- 1. Left indicator bar -->
                            <Border Grid.Column="0" CornerRadius="4,0,0,4">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TypeDisplay}" Value="报警">
                                                <Setter Property="Background" Value="#F74C5B"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding TypeDisplay}" Value="维护">
                                                <Setter Property="Background" Value="#F39C12"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding TypeDisplay}" Value="系统">
                                                <Setter Property="Background" Value="#5C6070"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>

                            <!-- 2. Status icon area -->
                            <Border Grid.Column="1"
                                    Width="36"
                                    Height="36"
                                    CornerRadius="6"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TypeDisplay}" Value="报警">
                                                <Setter Property="Background" Value="#2C1E21"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding TypeDisplay}" Value="维护">
                                                <Setter Property="Background" Value="#2C261E"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding TypeDisplay}" Value="系统">
                                                <Setter Property="Background" Value="#1E222D"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <materialDesign:PackIcon Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <materialDesign:PackIcon.Style>
                                        <Style TargetType="materialDesign:PackIcon">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TypeDisplay}" Value="报警">
                                                    <Setter Property="Kind" Value="AlertCircleOutline"/>
                                                    <Setter Property="Foreground" Value="#F74C5B"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding TypeDisplay}" Value="维护">
                                                    <Setter Property="Kind" Value="WrenchOutline"/>
                                                    <Setter Property="Foreground" Value="#F39C12"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding TypeDisplay}" Value="系统">
                                                    <Setter Property="Kind" Value="InformationOutline"/>
                                                    <Setter Property="Foreground" Value="#8A8D99"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </materialDesign:PackIcon.Style>
                                </materialDesign:PackIcon>
                            </Border>

                            <!-- 3. Content area -->
                            <Grid Grid.Column="2" VerticalAlignment="Center" Margin="8,14,16,14">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Row 0: Title + Status Badge -->
                                <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,6">
                                    <TextBlock Text="{Binding Title}"
                                               Foreground="#FFFFFF"
                                               FontSize="15"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"/>

                                    <Border Margin="10,0,0,0"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="6,1"
                                            VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRead}" Value="False">
                                                        <Setter Property="BorderBrush" Value="#F74C5B"/>
                                                        <Setter Property="Background" Value="#2C1E21"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsRead}" Value="True">
                                                        <Setter Property="BorderBrush" Value="#333645"/>
                                                        <Setter Property="Background" Value="Transparent"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="10" VerticalAlignment="Center" FontWeight="Normal">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRead}" Value="False">
                                                            <Setter Property="Text" Value="未读"/>
                                                            <Setter Property="Foreground" Value="#F74C5B"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsRead}" Value="True">
                                                            <Setter Property="Text" Value="已读"/>
                                                            <Setter Property="Foreground" Value="#8A8D99"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>

                                <!-- Row 1: Content -->
                                <TextBlock Grid.Row="1"
                                           Text="{Binding Content}"
                                           Foreground="#8A8D99"
                                           FontSize="13"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="NoWrap"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <!-- 4. Timestamp -->
                            <TextBlock Grid.Column="3"
                                       Text="{Binding Timestamp}"
                                       Foreground="#8A8D99"
                                       FontSize="13"
                                       FontFamily="Consolas"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="0,0,24,0"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
