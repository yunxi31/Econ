<Window x:Class="MotorTestSystem.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="系统登录" Height="420" Width="380"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources/>

    <Border CornerRadius="12" Background="#1B1E26" BorderBrush="#2B303C" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="2" Color="Black" Opacity="0.5"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar / Drag Area -->
            <Grid Grid.Row="0" Background="#161920" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0,0,0">
                    <Ellipse Width="8" Height="8" Fill="#00DFFF" Margin="0,0,8,0"/>
                    <TextBlock Text="系统安全登录" Foreground="#A0AAB2" FontSize="12" FontWeight="Bold"/>
                </StackPanel>
                <Button Grid.Column="1" Content="✕" Width="40" Height="40" Background="Transparent" BorderThickness="0" Foreground="#A0AAB2" FontSize="14" Click="CloseButton_Click" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FF3366"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Brand Header -->
            <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,30,0,10">
                <TextBlock Text="MOTOR TEST" Foreground="White" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="电机电性能测试系统" Foreground="#00DFFF" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Input Fields -->
            <Grid Grid.Row="2" Margin="35,10,35,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Role Selection -->
                <ComboBox x:Name="RoleComboBox" Grid.Row="0" Margin="0,10,0,14"
                          materialDesign:HintAssist.Hint="选择身份角色"
                          Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                          Foreground="White"
                          BorderBrush="#3A4250"
                          FontSize="14"
                          SelectedIndex="0"
                          SelectionChanged="RoleComboBox_SelectionChanged">
                    <ComboBox.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#1B1E26"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#D0D8E0"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#1E3040"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#00DFFF"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#22262F"/>
                    </ComboBox.Resources>
                    <ComboBoxItem Content="操作员 (Operator)"/>
                    <ComboBoxItem Content="维护员 (Maintainer)"/>
                    <ComboBoxItem Content="管理员 (Admin)"/>
                </ComboBox>

                <!-- Username -->
                <TextBox x:Name="UsernameTextBox" Grid.Row="1" Margin="0,10,0,15"
                         materialDesign:HintAssist.Hint="用户账号"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         Foreground="White"
                         BorderBrush="#2B303C"
                         IsEnabled="True"/>

                <!-- Password -->
                <PasswordBox x:Name="PasswordInput" Grid.Row="2" Margin="0,10,0,10"
                             materialDesign:HintAssist.Hint="安全密码"
                             Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                             Foreground="White"
                             BorderBrush="#2B303C"
                             KeyDown="PasswordBox_KeyDown"/>

                <!-- Error Messages -->
                <TextBlock x:Name="ErrorTextBlock" Grid.Row="3" Margin="0,5,0,0"
                           Foreground="#FF3366" FontSize="11" HorizontalAlignment="Left" 
                           TextWrapping="Wrap" Visibility="Collapsed"/>
            </Grid>

            <!-- Actions Footer -->
            <StackPanel Grid.Row="3" Margin="35,0,35,30">
                <!-- Login Button -->
                <Button Content="登 录" Height="42" FontSize="14" FontWeight="Bold"
                        Background="#00DFFF" Foreground="Black" BorderThickness="0"
                        Click="LoginButton_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
