<Window x:Class="MotorTestSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MotorTestSystem"
        xmlns:vm="clr-namespace:MotorTestSystem.ViewModels"
        xmlns:views="clr-namespace:MotorTestSystem.Views"
        mc:Ignorable="d"
        Title="电机电性能测试系统上位机" 
        Height="760" Width="1240"
        WindowStartupLocation="CenterScreen"
        Background="#12141A">

    <Window.Resources>
        <!-- Route ViewModels to Views -->
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MonitorViewModel}">
            <views:MonitorView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HistoryViewModel}">
            <views:HistoryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ConfigViewModel}">
            <views:ConfigView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDEBAR -->
        <Border Grid.Column="0" Background="#161920" BorderBrush="#2B303C" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- LOGO / HEADER -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse Width="12" Height="12" Fill="#00DFFF" Margin="0,0,10,0"/>
                    <TextBlock Text="MOTOR TEST" Foreground="White" FontSize="18" FontWeight="Bold"/>
                </StackPanel>

                <!-- NAV BUTTONS -->
                <StackPanel Grid.Row="1" Margin="10,20,10,0">
                    <!-- Navigation Styles -->
                    <StackPanel.Resources>
                        <Style TargetType="Button">
                            <Setter Property="Height" Value="45"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#A0AAB2"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            <Setter Property="Padding" Value="15,0,0,0"/>
                            <Setter Property="Margin" Value="0,5,0,5"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                                            <Grid>
                                                <!-- Selected Accent Left Strip -->
                                                <Border x:Name="leftAccent" HorizontalAlignment="Left" Width="4" Height="20" Background="#00DFFF" Visibility="Collapsed" CornerRadius="2" Margin="5,0,0,0"/>
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#232733"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </StackPanel.Resources>

                    <!-- Nav Button 1 -->
                    <Button Content="📊 生产看板" 
                            Command="{Binding NavigateCommand}" 
                            CommandParameter="Dashboard"/>

                    <!-- Nav Button 2 -->
                    <Button Content="⚙️ 工位监视" 
                            Command="{Binding NavigateCommand}" 
                            CommandParameter="Monitor"/>

                    <!-- Nav Button 3 -->
                    <Button Content="🔍 历史追溯" 
                            Command="{Binding NavigateCommand}" 
                            CommandParameter="History"/>

                    <!-- Nav Button 4 -->
                    <Button Content="🛠️ 通信配置" 
                            Command="{Binding NavigateCommand}" 
                            CommandParameter="Config"/>
                </StackPanel>

                <!-- User Info Profile footer -->
                <Border Grid.Row="2" Background="#1D222B" Margin="10" Padding="12" CornerRadius="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Ellipse Width="32" Height="32" Fill="#2B303C"/>
                        <TextBlock Text="👤" Foreground="#00DFFF" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="{Binding CurrentUser}" Foreground="White" FontSize="12" FontWeight="Bold"/>
                            <TextBlock Text="客户端操作员" Foreground="#A0AAB2" FontSize="10" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- RIGHT PANEL -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TOP STATUS HEADER -->
            <Border Grid.Row="0" Background="#161920" BorderBrush="#2B303C" BorderThickness="0,0,0,1">
                <Grid Margin="20,0,20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="电机电性能测试系统" Foreground="White" FontSize="16" FontWeight="Bold"/>
                        <Border Background="#2B303C" CornerRadius="4" Margin="12,0,0,0" Padding="6,2,6,2">
                            <TextBlock Text="v1.0.0" Foreground="#A0AAB2" FontSize="10" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>

                    <!-- Connectivity state -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="机台连接状态: " Foreground="#A0AAB2" FontSize="12" Margin="0,0,5,0"/>
                        <TextBlock Text="{Binding OnlineStationCount}" Foreground="#00FFB2" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text="/" Foreground="#A0AAB2" FontSize="12"/>
                        <TextBlock Text="{Binding TotalStationCount}" Foreground="White" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text=" 在线" Foreground="#A0AAB2" FontSize="12" Margin="3,0,0,0"/>
                    </StackPanel>

                    <!-- Clock -->
                    <TextBlock Grid.Column="2" Text="{Binding CurrentTime}" Foreground="#00DFFF" FontSize="14" FontWeight="Bold" FontFamily="Courier New" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- CURRENT ACTIVE VIEW PANEL -->
            <ContentControl Grid.Row="1" Content="{Binding CurrentView}"/>
        </Grid>
    </Grid>
</Window>
