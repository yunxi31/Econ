<Window x:Class="MotorTestSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MotorTestSystem.ViewModels"
        xmlns:views="clr-namespace:MotorTestSystem.Views"
        xmlns:conv="clr-namespace:MotorTestSystem.Converters"
        mc:Ignorable="d"
        Title="电机电性能测试系统"
        Height="920"
        Width="1280"
        MinHeight="760"
        MinWidth="1180"
        WindowStartupLocation="CenterScreen"
        Background="#090E12"
        FontFamily="Microsoft YaHei UI">

    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0" 
                      CornerRadius="0" 
                      CaptionHeight="102" 
                      UseAeroCaptionButtons="False" 
                      ResizeBorderThickness="7" />
    </WindowChrome.WindowChrome>


    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MonitorViewModel}">
            <views:MonitorView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HistoryViewModel}">
            <views:HistoryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ConfigViewModel}">
            <views:ConfigView/>
        </DataTemplate>

        <conv:ViewTypeToBoolConverter x:Key="ViewTypeToBoolConverter"/>

        <Style x:Key="SidebarTabStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="106"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#B8C4CC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GroupName" Value="SidebarGroup"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root" Background="{TemplateBinding Background}">
                            <Grid>
                                <Border x:Name="Accent"
                                        Width="4"
                                        HorizontalAlignment="Left"
                                        Background="#12D8F4"
                                        Visibility="Collapsed"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#14525A"/>
                                <Setter TargetName="Accent" Property="Visibility" Value="Visible"/>
                                <Setter Property="Foreground" Value="#11DDF7"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#17232A"/>
                                <Setter Property="Foreground" Value="#11DDF7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,9,0,0"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style x:Key="StatusDotStyle" TargetType="Ellipse">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Fill" Value="#00E68A"/>
            <Setter Property="Margin" Value="8,0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#00E68A" BlurRadius="13" ShadowDepth="0" Opacity="0.75"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Window Title Bar Buttons Style -->
        <Style x:Key="WindowControlButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A7B1BA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="8" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#252F3C"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#334052"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseControlButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A7B1BA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="8" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF3366"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#CC2952"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="#090E12">
        <Grid.Style>
            <Style TargetType="Grid">
                <Setter Property="Margin" Value="0"/>
                <Style.Triggers>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized"/>
                            <Condition Binding="{Binding WindowStyle, RelativeSource={RelativeSource AncestorType=Window}}" Value="SingleBorderWindow"/>
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Margin" Value="8"/>
                    </MultiDataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="102"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="102"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.RowSpan="2"
                Background="#151C22"
                BorderBrush="#36424B"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="102"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="128"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Path Data="M31,16 L46,16 L46,22 L39,22 L39,32 L55,32 L62,26 L68,32 L62,38 L55,38 L48,42 L48,62 L58,62 L58,70 L22,70 L22,62 L32,62 L32,42 L24,38 L18,38 L12,32 L18,26 L24,32 L32,32 L32,22 L31,22 Z M39,42 L39,62 L41,62 L41,42 Z"
                          Fill="#12DDF7"
                          Stretch="Uniform"
                          Width="48"
                          Height="48"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
                </Grid>

                <StackPanel Grid.Row="1">
                    <RadioButton Command="{Binding NavigateCommand}"
                                 CommandParameter="Monitor"
                                 IsChecked="{Binding CurrentView, Mode=OneWay, Converter={StaticResource ViewTypeToBoolConverter}, ConverterParameter=Monitor}"
                                 Style="{StaticResource SidebarTabStyle}">
                        <StackPanel>
                            <Path Data="M8,46 L8,31 L16,31 L16,46 Z M21,46 L21,24 L29,24 L29,46 Z M34,46 L34,17 L42,17 L42,46 Z M7,26 L20,15 L29,21 L43,6 L47,10 L30,28 L21,22 L10,31 Z"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  Width="38"
                                  Height="38"
                                  Stretch="Uniform"/>
                            <TextBlock Text="生产监控" Style="{StaticResource NavLabelStyle}"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Command="{Binding NavigateCommand}"
                                 CommandParameter="History"
                                 IsChecked="{Binding CurrentView, Mode=OneWay, Converter={StaticResource ViewTypeToBoolConverter}, ConverterParameter=History}"
                                 Style="{StaticResource SidebarTabStyle}">
                        <StackPanel>
                            <Path Data="M8,14 L28,14 M8,26 L28,26 M8,38 L20,38 M36,31 A11,11 0 1 0 36,53 A11,11 0 1 0 36,31 M44,48 L54,58"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  StrokeThickness="5"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Width="38"
                                  Height="38"
                                  Stretch="Uniform"/>
                            <TextBlock Text="数据追溯" Style="{StaticResource NavLabelStyle}"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Command="{Binding NavigateCommand}"
                                 CommandParameter="Dashboard"
                                 IsChecked="{Binding CurrentView, Mode=OneWay, Converter={StaticResource ViewTypeToBoolConverter}, ConverterParameter=Dashboard}"
                                 Style="{StaticResource SidebarTabStyle}">
                        <StackPanel>
                            <Path Data="M7,8 L45,8 L45,48 L7,48 Z M15,40 L15,30 M26,40 L26,20 M37,40 L37,26"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  StrokeThickness="5"
                                  StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Width="38"
                                  Height="38"
                                  Stretch="Uniform"/>
                            <TextBlock Text="生产看板" Style="{StaticResource NavLabelStyle}"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource SidebarTabStyle}">
                        <StackPanel>
                            <Path Data="M27,12 A10,10 0 1 0 27,32 A10,10 0 1 0 27,12 M8,51 C13,40 41,40 46,51 M43,17 L54,17 M48.5,11.5 L48.5,22.5 M43,33 L54,33"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  StrokeThickness="5"
                                  StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Width="38"
                                  Height="38"
                                  Stretch="Uniform"/>
                            <TextBlock Text="用户管理" Style="{StaticResource NavLabelStyle}"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

                <RadioButton Grid.Row="2"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="Config"
                             IsChecked="{Binding CurrentView, Mode=OneWay, Converter={StaticResource ViewTypeToBoolConverter}, ConverterParameter=Config}"
                             VerticalAlignment="Bottom"
                             Margin="0,0,0,22"
                             Style="{StaticResource SidebarTabStyle}">
                    <StackPanel>
                        <Path Data="M28,8 L34,8 L36,16 L43,19 L50,15 L54,21 L49,28 L50,36 L56,42 L52,49 L43,46 L36,50 L34,58 L26,58 L24,50 L17,47 L10,51 L6,44 L12,37 L11,29 L5,23 L9,16 L18,19 L24,16 Z M30,25 A8,8 0 1 0 30,41 A8,8 0 1 0 30,25"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                              StrokeThickness="4"
                              StrokeLineJoin="Round"
                              Width="38"
                              Height="38"
                              Stretch="Uniform"/>
                        <TextBlock Text="系统配置" Style="{StaticResource NavLabelStyle}"/>
                    </StackPanel>
                </RadioButton>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Grid.Row="0"
                Background="#10161B"
                BorderBrush="#34414A"
                BorderThickness="0,0,0,1">
            <Grid Margin="38,0,20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="42"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="28"/>
                    <ColumnDefinition Width="64"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="电机电性能测试系统"
                           Foreground="#12DDF7"
                           FontSize="27"
                           FontWeight="Light"
                           VerticalAlignment="Center"/>

                <Border Grid.Column="1"
                        Height="48"
                        Padding="26,0"
                        CornerRadius="19"
                        Background="#222A35"
                        BorderBrush="#334052"
                        BorderThickness="1.5"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="节点状态"
                                   Foreground="#B7C2CA"
                                   FontSize="15"
                                   VerticalAlignment="Center"
                                   Margin="0,0,18,0"/>
                        <Ellipse Style="{StaticResource StatusDotStyle}"/>
                        <Ellipse Style="{StaticResource StatusDotStyle}"/>
                        <Ellipse Style="{StaticResource StatusDotStyle}"/>
                        <Ellipse Style="{StaticResource StatusDotStyle}"/>
                        <Ellipse Style="{StaticResource StatusDotStyle}"/>
                        <Ellipse Width="16" Height="16" Fill="#FF5A5F" Margin="8,0">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#FF5A5F" BlurRadius="13" ShadowDepth="0" Opacity="0.75"/>
                            </Ellipse.Effect>
                        </Ellipse>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentTime}"
                               Foreground="#D7DEE7"
                               FontSize="30"
                               FontFamily="Consolas"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="UTC"
                               Foreground="#AEB8C2"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="24,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Border Grid.Column="5"
                        Width="64"
                        Height="64"
                        CornerRadius="18"
                        Background="#202936"
                        BorderBrush="#334052"
                        BorderThickness="1.5"
                        VerticalAlignment="Center"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        ToolTip="用户主页">
                    <Path Data="M24,22 A8,8 0 1 0 24,38 A8,8 0 1 0 24,22 M10,54 C14,43 34,43 38,54"
                          Stroke="#B8C4CC"
                          StrokeThickness="4"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Stretch="Uniform"
                          Width="30"
                          Height="30"/>
                </Border>

                <!-- Window Action Buttons -->
                <StackPanel Grid.Column="7" 
                            Orientation="Horizontal" 
                            VerticalAlignment="Center"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="BtnMinimize" Click="BtnMinimize_Click" Style="{StaticResource WindowControlButtonStyle}" ToolTip="最小化">
                        <Path Data="M0,8 L16,8" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="2" Width="12" Height="12" Stretch="Uniform"/>
                    </Button>
                    <Button x:Name="BtnMaximize" Click="BtnMaximize_Click" Style="{StaticResource WindowControlButtonStyle}" ToolTip="最大化">
                        <Path x:Name="MaximizeIcon" Data="M1,1 L15,1 L15,15 L1,15 Z" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="2" Width="12" Height="12" Stretch="Uniform"/>
                    </Button>
                    <Button x:Name="BtnFullscreen" Click="BtnFullscreen_Click" Style="{StaticResource WindowControlButtonStyle}" ToolTip="全屏 (F11)">
                        <Path x:Name="FullscreenIcon" Data="M1,5 L1,1 L5,1 M11,1 L15,1 L15,5 M15,11 L15,15 L11,15 M5,15 L1,15 L1,11" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="2" Width="12" Height="12" Stretch="Uniform"/>
                    </Button>
                    <Button x:Name="BtnClose" Click="BtnClose_Click" Style="{StaticResource CloseControlButtonStyle}" ToolTip="关闭">
                        <Path Data="M1,1 L15,15 M15,1 L1,15" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="2" Width="12" Height="12" Stretch="Uniform"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <ContentControl Grid.Column="1"
                        Grid.Row="1"
                        Content="{Binding CurrentView}"/>
    </Grid>
</Window>
