<Window x:Class="MotorTestSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MotorTestSystem.ViewModels"
        xmlns:views="clr-namespace:MotorTestSystem.Views"
        xmlns:conv="clr-namespace:MotorTestSystem.Converters"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:MotorTestSystem"
        mc:Ignorable="d"
        Title="{local:Loc 电机电性能测试系统}"
        Height="920"
        Width="1280"
        MinHeight="760"
        MinWidth="1180"
        WindowStartupLocation="CenterScreen"
        Background="#090E12"
        FontFamily="Microsoft YaHei UI">

    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0" 
                      CornerRadius="0" 
                      CaptionHeight="102" 
                      UseAeroCaptionButtons="False" 
                      ResizeBorderThickness="7" />
    </WindowChrome.WindowChrome>


    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MonitorViewModel}">
            <views:MonitorView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HistoryViewModel}">
            <views:HistoryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ConfigViewModel}">
            <views:ConfigView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:UserViewModel}">
            <views:UserView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NotificationCenterViewModel}">
            <views:NotificationCenterView/>
        </DataTemplate>

        <conv:ViewTypeToBoolConverter x:Key="ViewTypeToBoolConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisConverter"/>

        <Style x:Key="NotificationBellButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="64"/>
            <Setter Property="Height" Value="64"/>
            <Setter Property="Background" Value="#202936"/>
            <Setter Property="BorderBrush" Value="#334052"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <Grid>
                                <!-- Bell Icon -->
                                <materialDesign:PackIcon Kind="BellOutline" 
                                                         Width="30" 
                                                         Height="30" 
                                                         Foreground="#B8C4CC" 
                                                         HorizontalAlignment="Center" 
                                                         VerticalAlignment="Center"
                                                         x:Name="Icon"/>
                                
                                <!-- Red Badge for Unread Count -->
                                <Border x:Name="BadgeBorder"
                                        Background="#FF3B30"
                                        CornerRadius="8"
                                        MinWidth="16"
                                        Height="16"
                                        Padding="4,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="0,6,6,0"
                                        Visibility="Visible">
                                    <TextBlock Text="{Binding DataContext.NotificationVM.UnreadCount, RelativeSource={RelativeSource AncestorType=Window}}"
                                               Foreground="White"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Mouse Over -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A3442"/>
                                <Setter TargetName="Icon" Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <!-- Clicked -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1C222B"/>
                            </Trigger>
                            <!-- Hide badge if unread count is 0 -->
                            <DataTrigger Binding="{Binding DataContext.NotificationVM.UnreadCount, RelativeSource={RelativeSource AncestorType=Window}}" Value="0">
                                <Setter TargetName="BadgeBorder" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LanguageToggleButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="64"/>
            <Setter Property="Height" Value="64"/>
            <Setter Property="Background" Value="#202936"/>
            <Setter Property="BorderBrush" Value="#334052"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <TextBlock x:Name="Txt"
                                       Text="{Binding Source={x:Static local:LanguageManager.Instance}, Path=CurrentLanguage}"
                                       Foreground="#B8C4CC" 
                                       FontSize="16"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A3442"/>
                                <Setter TargetName="Txt" Property="Foreground" Value="#12DDF7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1C222B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarTabStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="106"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#B8C4CC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GroupName" Value="SidebarGroup"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root" Background="{TemplateBinding Background}">
                            <Grid>
                                <Border x:Name="Accent"
                                        Width="4"
                                        HorizontalAlignment="Left"
                                        Background="#12D8F4"
                                        Visibility="Collapsed"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#14525A"/>
                                <Setter TargetName="Accent" Property="Visibility" Value="Visible"/>
                                <Setter Property="Foreground" Value="#11DDF7"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#17232A"/>
                                <Setter Property="Foreground" Value="#11DDF7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,9,0,0"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style x:Key="StatusDotStyle" TargetType="Ellipse">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Margin" Value="8,0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="0">
                    <Setter Property="Fill" Value="#78838C"/>
                    <Setter Property="Effect" Value="{x:Null}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="1">
                    <Setter Property="Fill" Value="#00E68A"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#00E68A" BlurRadius="13" ShadowDepth="0" Opacity="0.75"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="2">
                    <Setter Property="Fill" Value="#FF5A5F"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#FF5A5F" BlurRadius="13" ShadowDepth="0" Opacity="0.75"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Window Title Bar Buttons Style -->
        <Style x:Key="WindowControlButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A7B1BA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="8" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#252F3C"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#334052"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseControlButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A7B1BA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="8" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF3366"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#CC2952"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="#090E12">
        <Grid.Style>
            <Style TargetType="Grid">
                <Setter Property="Margin" Value="0"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                        <Setter Property="Margin" Value="8"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.RowSpan="2"
                Width="102"
                Background="#151C22"
                BorderBrush="#36424B"
                BorderThickness="0,0,1,0">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsNotificationCenterActive}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="102"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="128"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Path Data="M31,16 L46,16 L46,22 L39,22 L39,32 L55,32 L62,26 L68,32 L62,38 L55,38 L48,42 L48,62 L58,62 L58,70 L22,70 L22,62 L32,62 L32,42 L24,38 L18,38 L12,32 L18,26 L24,32 L32,32 L32,22 L31,22 Z M39,42 L39,62 L41,62 L41,42 Z"
                          Fill="#12DDF7"
                          Stretch="Uniform"
                          Width="48"
                          Height="48"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
                </Grid>

                <StackPanel Grid.Row="1">
                    <RadioButton Command="{Binding NavigateCommand}"
                                 CommandParameter="Monitor"
                                 IsChecked="{Binding CurrentView, Mode=OneWay, Converter={StaticResource ViewTypeToBoolConverter}, ConverterParameter=Monitor}"
                                 Visibility="{Binding IsMonitorVisible, Converter={StaticResource BoolToVisConverter}}"
                                 Style="{StaticResource SidebarTabStyle}">
                        <StackPanel>
                            <Path Data="M8,46 L8,31 L16,31 L16,46 Z M21,46 L21,24 L29,24 L29,46 Z M34,46 L34,17 L42,17 L42,46 Z M7,26 L20,15 L29,21 L43,6 L47,10 L30,28 L21,22 L10,31 Z"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  Width="38"
                                  Height="38"
                                  Stretch="Uniform"/>
                            <TextBlock Text="{local:Loc 生产监控}" Style="{StaticResource NavLabelStyle}"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Command="{Binding NavigateCommand}"
                                 CommandParameter="History"
                                 IsChecked="{Binding CurrentView, Mode=OneWay, Converter={StaticResource ViewTypeToBoolConverter}, ConverterParameter=History}"
                                 Visibility="{Binding IsHistoryVisible, Converter={StaticResource BoolToVisConverter}}"
                                 Style="{StaticResource SidebarTabStyle}">
                        <StackPanel>
                            <Path Data="M8,14 L28,14 M8,26 L28,26 M8,38 L20,38 M36,31 A11,11 0 1 0 36,53 A11,11 0 1 0 36,31 M44,48 L54,58"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  StrokeThickness="5"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Width="38"
                                  Height="38"
                                  Stretch="Uniform"/>
                            <TextBlock Text="{local:Loc 数据追溯}" Style="{StaticResource NavLabelStyle}"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Command="{Binding NavigateCommand}"
                                 CommandParameter="Dashboard"
                                 IsChecked="{Binding CurrentView, Mode=OneWay, Converter={StaticResource ViewTypeToBoolConverter}, ConverterParameter=Dashboard}"
                                 Visibility="{Binding IsDashboardVisible, Converter={StaticResource BoolToVisConverter}}"
                                 Style="{StaticResource SidebarTabStyle}">
                        <StackPanel>
                            <Path Data="M7,8 L45,8 L45,48 L7,48 Z M15,40 L15,30 M26,40 L26,20 M37,40 L37,26"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  StrokeThickness="5"
                                  StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Width="38"
                                  Height="38"
                                  Stretch="Uniform"/>
                            <TextBlock Text="{local:Loc 生产看板}" Style="{StaticResource NavLabelStyle}"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Command="{Binding NavigateCommand}"
                                 CommandParameter="User"
                                 IsChecked="{Binding CurrentView, Mode=OneWay, Converter={StaticResource ViewTypeToBoolConverter}, ConverterParameter=User}"
                                 Visibility="{Binding IsUserVisible, Converter={StaticResource BoolToVisConverter}}"
                                 Style="{StaticResource SidebarTabStyle}">
                        <StackPanel>
                            <Path Data="M27,12 A10,10 0 1 0 27,32 A10,10 0 1 0 27,12 M8,51 C13,40 41,40 46,51 M43,17 L54,17 M48.5,11.5 L48.5,22.5 M43,33 L54,33"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  StrokeThickness="5"
                                  StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Width="38"
                                  Height="38"
                                  Stretch="Uniform"/>
                            <TextBlock Text="{local:Loc 用户管理}" Style="{StaticResource NavLabelStyle}"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Command="{Binding NavigateCommand}"
                                 CommandParameter="LogCenter"
                                 IsChecked="{Binding CurrentView, Mode=OneWay, Converter={StaticResource ViewTypeToBoolConverter}, ConverterParameter=LogCenter}"
                                 Style="{StaticResource SidebarTabStyle}">
                        <StackPanel>
                            <Path Data="M8,4 L32,4 L40,12 L40,44 L8,44 Z M8,12 L32,12 L32,4 M14,20 L34,20 M14,28 L34,28 M14,36 L26,36"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  StrokeThickness="4.5"
                                  StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Width="34"
                                  Height="34"
                                  Stretch="Uniform"/>
                            <TextBlock Text="{local:Loc 日志中心}" Style="{StaticResource NavLabelStyle}"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

                <RadioButton Grid.Row="2"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="Config"
                             IsChecked="{Binding CurrentView, Mode=OneWay, Converter={StaticResource ViewTypeToBoolConverter}, ConverterParameter=Config}"
                             Visibility="{Binding IsConfigVisible, Converter={StaticResource BoolToVisConverter}}"
                             VerticalAlignment="Bottom"
                             Margin="0,0,0,22"
                             Style="{StaticResource SidebarTabStyle}">
                    <StackPanel>
                        <Path Data="M28,8 L34,8 L36,16 L43,19 L50,15 L54,21 L49,28 L50,36 L56,42 L52,49 L43,46 L36,50 L34,58 L26,58 L24,50 L17,47 L10,51 L6,44 L12,37 L11,29 L5,23 L9,16 L18,19 L24,16 Z M30,25 A8,8 0 1 0 30,41 A8,8 0 1 0 30,25"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                              StrokeThickness="4"
                              StrokeLineJoin="Round"
                              Width="38"
                              Height="38"
                              Stretch="Uniform"/>
                        <TextBlock Text="{local:Loc 系统配置}" Style="{StaticResource NavLabelStyle}"/>
                    </StackPanel>
                </RadioButton>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Grid.Row="0"
                Height="102"
                Background="#10161B"
                BorderBrush="#34414A"
                BorderThickness="0,0,0,1">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsNotificationCenterActive}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid Margin="38,0,20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/> <!-- Node Status -->
                    <ColumnDefinition Width="32"/>   <!-- Spacer -->
                    <ColumnDefinition Width="Auto"/> <!-- CurrentTime -->
                    <ColumnDefinition Width="32"/>   <!-- Spacer -->
                    <ColumnDefinition Width="Auto"/> <!-- Notification -->
                    <ColumnDefinition Width="24"/>   <!-- Spacer -->
                    <ColumnDefinition Width="Auto"/> <!-- Language Toggle -->
                    <ColumnDefinition Width="24"/>   <!-- Spacer -->
                    <ColumnDefinition Width="Auto"/> <!-- UserAvatar -->
                    <ColumnDefinition Width="16"/>   <!-- Right Spacer -->
                </Grid.ColumnDefinitions>

                <TextBlock Text="{local:Loc 电机电性能测试系统}"
                           Foreground="#12DDF7"
                           FontSize="27"
                           FontWeight="Light"
                           VerticalAlignment="Center"/>

                <Border Grid.Column="1"
                        Height="48"
                        Padding="26,0"
                        CornerRadius="19"
                        Background="#10161B"
                        BorderBrush="#34414A"
                        BorderThickness="1.5"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{local:Loc 节点状态}"
                                   Foreground="#B7C2CA"
                                   FontSize="15"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <ItemsControl ItemsSource="{Binding HeaderStations}" Focusable="False" BorderThickness="0" Background="Transparent">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Ellipse Style="{StaticResource StatusDotStyle}" ToolTip="{Binding DisplayToolTip}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentTime}"
                               Foreground="#D7DEE7"
                               FontSize="30"
                               FontFamily="Consolas"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="5"
                        Command="{Binding NavigateCommand}"
                        CommandParameter="Notification"
                        Style="{StaticResource NotificationBellButtonStyle}"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        VerticalAlignment="Center"/>

                <Button Grid.Column="7"
                        Click="LanguageToggleButton_Click"
                        Style="{StaticResource LanguageToggleButtonStyle}"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        VerticalAlignment="Center"
                        ToolTip="ZH/EN"/>

                <Border x:Name="UserAvatarBorder" Grid.Column="9"
                        Width="64"
                        Height="64"
                        CornerRadius="18"
                        Background="#202936"
                        BorderBrush="#334052"
                        BorderThickness="1.5"
                        VerticalAlignment="Center"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        ToolTip="{local:Loc 用户主页}"
                        Cursor="Hand"
                        MouseLeftButtonDown="UserAvatarBorder_MouseLeftButtonDown">
                    <Grid>
                        <Path Data="M24,22 A8,8 0 1 0 24,38 A8,8 0 1 0 24,22 M10,54 C14,43 34,43 38,54"
                              Stroke="#B8C4CC"
                              StrokeThickness="4"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Stretch="Uniform"
                              Width="30"
                              Height="30"/>

                        <!-- 用户信息悬浮卡片 -->
                        <Popup x:Name="UserCardPopup"
                               PlacementTarget="{Binding ElementName=UserAvatarBorder}"
                               Placement="Bottom"
                               VerticalOffset="8"
                               HorizontalOffset="-140"
                               AllowsTransparency="True"
                               StaysOpen="True"
                               PopupAnimation="Fade">
                            <Border Background="#151C22"
                                    BorderBrush="#334052"
                                    BorderThickness="1.5"
                                    CornerRadius="12"
                                    Width="220"
                                    Padding="16">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="3" Opacity="0.5"/>
                                </Border.Effect>
                                <StackPanel>
                                    <!-- 用户名 -->
                                    <TextBlock Text="{local:Loc 用户名}" Foreground="#5F7585" FontSize="12" Margin="0,0,0,4"/>
                                    <Border Background="#202936"
                                            BorderBrush="#334052"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="8,6"
                                            Margin="0,0,0,12">
                                        <TextBlock Text="{Binding CurrentUserName}"
                                                   Foreground="White"
                                                   FontSize="14"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- 角色 -->
                                    <TextBlock Text="{local:Loc 用户角色}" Foreground="#5F7585" FontSize="12" Margin="0,0,0,4"/>
                                    <Border Background="#202936"
                                            BorderBrush="#334052"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="8,6"
                                            Margin="0,0,0,16">
                                        <TextBlock Text="{Binding CurrentUserRole}"
                                                   Foreground="White"
                                                   FontSize="14"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- 退出登录按钮 -->
                                    <Button x:Name="LogoutButton"
                                            Content="{local:Loc 退出登录}"
                                            Click="LogoutButton_Click"
                                            Height="34"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            FontWeight="Bold">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="6"/>
                                            </Style>
                                        </Button.Resources>
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="#FF3B30"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#FF453A"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter Property="Background" Value="#D0342C"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                </Border>

                <!-- Removed Window Action Buttons as per user request -->
            </Grid>
        </Border>

        <ContentControl Content="{Binding CurrentView}">
            <ContentControl.Style>
                <Style TargetType="ContentControl">
                    <!-- Default state: sits in column 1, row 1 -->
                    <Setter Property="Grid.Column" Value="1"/>
                    <Setter Property="Grid.Row" Value="1"/>
                    <Setter Property="Grid.ColumnSpan" Value="1"/>
                    <Setter Property="Grid.RowSpan" Value="1"/>
                    <Style.Triggers>
                        <!-- Full screen mode: spans all rows and columns -->
                        <DataTrigger Binding="{Binding IsNotificationCenterActive}" Value="True">
                            <Setter Property="Grid.Column" Value="0"/>
                            <Setter Property="Grid.Row" Value="0"/>
                            <Setter Property="Grid.ColumnSpan" Value="2"/>
                            <Setter Property="Grid.RowSpan" Value="2"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ContentControl.Style>
        </ContentControl>
    </Grid>
</Window>
