<UserControl x:Class="MotorTestSystem.Views.NotificationCenterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.expression/blend/2008" 
             xmlns:local="clr-namespace:MotorTestSystem.Views"
             xmlns:vm="clr-namespace:MotorTestSystem.ViewModels"
             xmlns:conv="clr-namespace:MotorTestSystem.Converters"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:root="clr-namespace:MotorTestSystem"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             mc:Ignorable="d" 
             d:DesignHeight="760" d:DesignWidth="1080"
             Background="#13141E"
             Language="{Binding Source={x:Static root:LanguageManager.Instance}, Path=CurrentLanguage, Converter={StaticResource LanguageToXmlLanguageConverter}, ConverterCulture=en-US}">

    <UserControl.Resources>
        <!-- Converters -->
        <conv:StringEqualsToBoolConverter x:Key="StringEqualsToBoolConverter"/>

        <!-- Custom Calendar Button Styles -->
        <Style x:Key="DarkCalendarDayButtonStyle" TargetType="CalendarDayButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="MinWidth" Value="24"/>
            <Setter Property="MinHeight" Value="24"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CalendarDayButton">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="4" Margin="1">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#2A2E3D"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#00D2E6"/>
                                <Setter Property="Foreground" Value="#13141E"/>
                            </Trigger>
                            <Trigger Property="IsToday" Value="True">
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#00D2E6"/>
                                <Setter TargetName="Bg" Property="BorderThickness" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsInactive" Value="True">
                                <Setter Property="Foreground" Value="#4E5266"/>
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkCalendarButtonStyle" TargetType="CalendarButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CalendarButton">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="4" Margin="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#2A2E3D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom Dark CalendarItem Style -->
        <Style x:Key="DarkCalendarItemStyle" TargetType="{x:Type primitives:CalendarItem}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type primitives:CalendarItem}">
                        <ControlTemplate.Resources>
                            <!-- Day title template (e.g. Sun, Mon) -->
                            <DataTemplate x:Key="{ComponentResourceKey TypeInTargetAssembly={x:Type primitives:CalendarItem}, ResourceId=DayTitleTemplate}">
                                <TextBlock Text="{Binding}" 
                                           FontFamily="Segoe UI" 
                                           FontWeight="SemiBold" 
                                           FontSize="11" 
                                           Foreground="#8A8D99" 
                                           Margin="0,8,0,8" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center" />
                            </DataTemplate>
                        </ControlTemplate.Resources>
                        
                        <Grid Name="PART_Root">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup Name="CommonStates"/>
                            </VisualStateManager.VisualStateGroups>
                            
                            <Border BorderThickness="1" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    Background="{TemplateBinding Background}" 
                                    CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="40" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <!-- Prev Button -->
                                    <Button Name="PART_PreviousButton" Width="28" Height="28" 
                                            Style="{x:Null}"
                                            HorizontalAlignment="Left" VerticalAlignment="Center"
                                            Margin="8,0,0,0" Focusable="False" Grid.Column="0" Grid.Row="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="BtnBorder" Background="Transparent" CornerRadius="4" Cursor="Hand">
                                                    <Path x:Name="arrow" Data="M288.75,232.25L288.75,240.625 283,236.625z" 
                                                          Stretch="Fill" Fill="#FFFFFF" Width="6" Height="10" 
                                                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="BtnBorder" Property="Background" Value="#2A2E3D"/>
                                                        <Setter TargetName="arrow" Property="Fill" Value="#00D2E6"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="arrow" Property="Fill" Value="#55586A"/>
                                                        <Setter TargetName="BtnBorder" Property="Opacity" Value="0.35"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- Header Button (Month/Year) -->
                                    <Button Name="PART_HeaderButton" 
                                            Style="{x:Null}"
                                            Foreground="#FFFFFF"
                                            HorizontalAlignment="Center" VerticalAlignment="Center" 
                                            FontSize="13" FontWeight="SemiBold"
                                            Focusable="False" Grid.Column="1" Grid.Row="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="BtnBorder" Background="Transparent" CornerRadius="4" Padding="8,4,8,4" Cursor="Hand">
                                                    <TextBlock Text="{TemplateBinding Content}" 
                                                               Foreground="{TemplateBinding Foreground}"
                                                               HorizontalAlignment="Center" 
                                                               VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Foreground" Value="#00D2E6"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter Property="Foreground" Value="#55586A"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- Next Button -->
                                    <Button Name="PART_NextButton" Width="28" Height="28" 
                                            Style="{x:Null}"
                                            HorizontalAlignment="Right" VerticalAlignment="Center"
                                            Margin="0,0,8,0" Focusable="False" Grid.Column="2" Grid.Row="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="BtnBorder" Background="Transparent" CornerRadius="4" Cursor="Hand">
                                                    <Path x:Name="arrow" Data="M282.875,231.875L282.875,240.375 288.625,236z" 
                                                          Stretch="Fill" Fill="#FFFFFF" Width="6" Height="10" 
                                                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="BtnBorder" Property="Background" Value="#2A2E3D"/>
                                                        <Setter TargetName="arrow" Property="Fill" Value="#00D2E6"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="arrow" Property="Fill" Value="#55586A"/>
                                                        <Setter TargetName="BtnBorder" Property="Opacity" Value="0.35"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- Grid views -->
                                    <Grid Name="PART_MonthView" Margin="8,0,8,8" 
                                          HorizontalAlignment="Center" Visibility="Visible" 
                                          Grid.Row="1" Grid.ColumnSpan="3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                    </Grid>
                                    
                                    <Grid Name="PART_YearView" Margin="8,0,8,8" 
                                          HorizontalAlignment="Center" Visibility="Hidden" 
                                          Grid.Row="1" Grid.ColumnSpan="3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                    </Grid>
                                </Grid>
                            </Border>
                            
                            <Rectangle RadiusX="2" RadiusY="2" Stretch="Fill" Fill="#A5FFFFFF" 
                                       Stroke="#A5FFFFFF" StrokeThickness="1" 
                                       Name="PART_DisabledVisual" Opacity="0" Visibility="Collapsed" />
                        </Grid>
                        
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Visibility" TargetName="PART_DisabledVisual" Value="Visible" />
                                <Setter Property="Opacity" TargetName="PART_DisabledVisual" Value="0.5" />
                            </Trigger>
                            <DataTrigger Binding="{Binding Path=DisplayMode, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Calendar}}" Value="Year">
                                <Setter Property="Visibility" TargetName="PART_MonthView" Value="Hidden" />
                                <Setter Property="Visibility" TargetName="PART_YearView" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Path=DisplayMode, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Calendar}}" Value="Decade">
                                <Setter Property="Visibility" TargetName="PART_MonthView" Value="Hidden" />
                                <Setter Property="Visibility" TargetName="PART_YearView" Value="Visible" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom Dark Calendar Style -->
        <Style x:Key="DarkCalendarStyle" TargetType="Calendar">
            <Setter Property="Background" Value="#181924"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#333645"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CalendarDayButtonStyle" Value="{StaticResource DarkCalendarDayButtonStyle}"/>
            <Setter Property="CalendarButtonStyle" Value="{StaticResource DarkCalendarButtonStyle}"/>
            <Setter Property="CalendarItemStyle" Value="{StaticResource DarkCalendarItemStyle}"/>
        </Style>


        <SolidColorBrush x:Key="BackgroundDark" Color="#13141E"/>
        <SolidColorBrush x:Key="PanelBackground" Color="#212431"/>
        <SolidColorBrush x:Key="AccentCyan" Color="#00D2E6"/>
        <SolidColorBrush x:Key="AccentRed" Color="#F74C5B"/>
        <SolidColorBrush x:Key="AccentWarning" Color="#F39C12"/>
        <SolidColorBrush x:Key="AccentSystem" Color="#5C6070"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8A8D99"/>

        <!-- Header Button Style -->
        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="#1B1C28"/>
            <Setter Property="BorderBrush" Value="#333645"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#8A8D99"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="12,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#252736"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                    <Setter Property="BorderBrush" Value="#45495E"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#151620"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Base Pill RadioButton Style -->
        <Style x:Key="PillRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="#1B1C28"/>
            <Setter Property="BorderBrush" Value="#333645"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#8A8D99"/>
            <Setter Property="GroupName" Value="FilterPills"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="PillBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18"
                                Padding="16,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Icon (if Tag is set) -->
                                <materialDesign:PackIcon x:Name="PillIcon"
                                                         Kind="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                                         Width="16"
                                                         Height="16"
                                                         Margin="0,0,8,0"
                                                         VerticalAlignment="Center"/>
                                <!-- Text / Badge content -->
                                <ContentPresenter x:Name="PillText"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="False"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="{x:Null}">
                                <Setter TargetName="PillIcon" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PillBorder" Property="Background" Value="#252736"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Pill colors on selection -->
        <Style x:Key="AllPillStyle" TargetType="RadioButton" BasedOn="{StaticResource PillRadioButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#00D2E6"/>
                    <Setter Property="BorderBrush" Value="#00D2E6"/>
                    <Setter Property="Foreground" Value="#090E12"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AlarmPillStyle" TargetType="RadioButton" BasedOn="{StaticResource PillRadioButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#F74C5B"/>
                    <Setter Property="BorderBrush" Value="#F74C5B"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MaintenancePillStyle" TargetType="RadioButton" BasedOn="{StaticResource PillRadioButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#F39C12"/>
                    <Setter Property="BorderBrush" Value="#F39C12"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SystemPillStyle" TargetType="RadioButton" BasedOn="{StaticResource PillRadioButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#5C6070"/>
                    <Setter Property="BorderBrush" Value="#5C6070"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ListBoxItem Style to strip selection styles -->
        <Style x:Key="NotificationListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0,0,0,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Pagination Button Style -->
        <Style x:Key="PaginationButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1B1C28"/>
            <Setter Property="BorderBrush" Value="#333645"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#8A8D99"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#252736"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Log Tab Button Style -->
        <Style x:Key="LogTabButtonStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Foreground" Value="#8A8D99"/>
            <Setter Property="GroupName" Value="LogTabs"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,24,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="TabBorder"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0,0,0,2"
                                Padding="4,4,4,8">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#00D2E6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Foreground" Value="#00D2E6"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Level Filter Button Style -->
        <Style x:Key="LevelFilterButtonStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="#1B1C28"/>
            <Setter Property="BorderBrush" Value="#333645"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#B0B8CC"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#252736"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="38,30,38,30">
        <Grid.RowDefinitions>
            <!-- 0. Header (Title + Buttons) -->
            <RowDefinition Height="Auto"/>
            <!-- 1. Filters -->
            <RowDefinition Height="Auto"/>
            <!-- 2. Tabs (运行日志 / 操作日志) -->
            <RowDefinition Height="Auto"/>
            <!-- 3. Main DataGrid -->
            <RowDefinition Height="*"/>
            <!-- 4. Bottom Pagination -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 0. Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Icon + Title -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <materialDesign:PackIcon Kind="{Binding PageIcon}"
                                         Width="28"
                                         Height="28"
                                         Foreground="#FFFFFF"
                                         VerticalAlignment="Center"/>
                <TextBlock Foreground="#FFFFFF"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center">
                    <TextBlock.Text>
                        <MultiBinding Converter="{StaticResource LocMultiConverter}">
                            <Binding Path="PageTitle" />
                            <Binding Source="{x:Static root:LanguageManager.Instance}" Path="CurrentLanguage" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>

            <!-- Right: Export Action -->
            <Button Grid.Column="1" Command="{Binding ExportCsvCommand}"
                    Style="{StaticResource HeaderButtonStyle}" Padding="16,0" Height="40">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="DownloadOutline" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#00D2E6"/>
                    <TextBlock Text="{root:Loc 导出 CSV}" FontSize="14" FontWeight="SemiBold" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- 1. Filters -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/> <!-- 时间范围 -->
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="Auto"/> <!-- 来源/机台 -->
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="Auto"/> <!-- 级别筛选 -->
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="260"/> <!-- 搜索框 -->
            </Grid.ColumnDefinitions>

            <!-- 1.1 时间范围 -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{root:Loc 时间范围}" Foreground="#B0B8CC" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <Border Background="#1B1C28" BorderBrush="#333645" BorderThickness="1" CornerRadius="4" Padding="8,0" Height="36">
                    <DatePicker x:Name="StartDatePicker"
                                SelectedDate="{Binding StartDate}"
                                materialDesign:CalendarAssist.IsHeaderVisible="False"
                                CalendarStyle="{StaticResource DarkCalendarStyle}"
                                Language="zh-CN"
                                Foreground="#FFFFFF" FontFamily="Consolas" FontSize="14"
                                VerticalAlignment="Center" BorderThickness="0" Background="Transparent" Width="110"
                                Focusable="False"/>
                </Border>
                <TextBlock Text="{root:Loc 至}" Foreground="#B0B8CC" FontSize="14" Margin="8,0" VerticalAlignment="Center"/>
                <Border Background="#1B1C28" BorderBrush="#333645" BorderThickness="1" CornerRadius="4" Padding="8,0" Height="36">
                    <DatePicker x:Name="EndDatePicker"
                                SelectedDate="{Binding EndDate}"
                                materialDesign:CalendarAssist.IsHeaderVisible="False"
                                CalendarStyle="{StaticResource DarkCalendarStyle}"
                                Foreground="#FFFFFF" FontFamily="Consolas" FontSize="14"
                                VerticalAlignment="Center" BorderThickness="0" Background="Transparent" Width="110"
                                Focusable="False"/>
                </Border>
            </StackPanel>

            <!-- 1.2 来源/机台 -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{root:Loc 来源/机台}" Foreground="#B0B8CC" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <ComboBox Width="130" Height="36"
                          ItemsSource="{Binding Sources}"
                          SelectedItem="{Binding SelectedSource, Mode=TwoWay}"
                          Background="#1B1C28"
                          BorderBrush="#333645"
                          Foreground="#FFFFFF"
                          FontSize="14"
                          VerticalAlignment="Center"
                          HorizontalContentAlignment="Center"
                          VerticalContentAlignment="Center"
                          Padding="0">
                    <ComboBox.Resources>
                        <SolidColorBrush x:Key="MaterialDesignPaper" Color="#1B1C28"/>
                        <SolidColorBrush x:Key="MaterialDesignBody" Color="#FFFFFF"/>
                    </ComboBox.Resources>
                </ComboBox>
            </StackPanel>

            <!-- 1.3 级别筛选 -->
            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{root:Loc 级别}" Foreground="#B0B8CC" FontSize="14" Margin="0,0,12,0" VerticalAlignment="Center"/>
                
                <RadioButton Content="ALL"
                             Style="{StaticResource LevelFilterButtonStyle}"
                             IsChecked="{Binding SelectedFilter, Converter={StaticResource StringEqualsToBoolConverter}, ConverterParameter=全部, Mode=TwoWay}">
                    <RadioButton.Resources>
                        <Style TargetType="RadioButton" BasedOn="{StaticResource LevelFilterButtonStyle}">
                            <Style.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Background" Value="#00D2E6"/>
                                    <Setter Property="BorderBrush" Value="#00D2E6"/>
                                    <Setter Property="Foreground" Value="#090E12"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </RadioButton.Resources>
                </RadioButton>

                <RadioButton Content="INFO"
                             Style="{StaticResource LevelFilterButtonStyle}"
                             IsChecked="{Binding SelectedFilter, Converter={StaticResource StringEqualsToBoolConverter}, ConverterParameter=系统, Mode=TwoWay}">
                    <RadioButton.Resources>
                        <Style TargetType="RadioButton" BasedOn="{StaticResource LevelFilterButtonStyle}">
                            <Style.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Background" Value="#2B2D38"/>
                                    <Setter Property="BorderBrush" Value="#5C6070"/>
                                    <Setter Property="Foreground" Value="#B8C4CC"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </RadioButton.Resources>
                </RadioButton>

                <RadioButton Content="WARN"
                             Style="{StaticResource LevelFilterButtonStyle}"
                             IsChecked="{Binding SelectedFilter, Converter={StaticResource StringEqualsToBoolConverter}, ConverterParameter=维护, Mode=TwoWay}">
                    <RadioButton.Resources>
                        <Style TargetType="RadioButton" BasedOn="{StaticResource LevelFilterButtonStyle}">
                            <Style.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Background" Value="#2A2114"/>
                                    <Setter Property="BorderBrush" Value="#F39C12"/>
                                    <Setter Property="Foreground" Value="#F39C12"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </RadioButton.Resources>
                </RadioButton>

                <RadioButton Content="ERROR"
                             Style="{StaticResource LevelFilterButtonStyle}"
                             IsChecked="{Binding SelectedFilter, Converter={StaticResource StringEqualsToBoolConverter}, ConverterParameter=报警, Mode=TwoWay}">
                    <RadioButton.Resources>
                        <Style TargetType="RadioButton" BasedOn="{StaticResource LevelFilterButtonStyle}">
                            <Style.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Background" Value="#2A1418"/>
                                    <Setter Property="BorderBrush" Value="#F74C5B"/>
                                    <Setter Property="Foreground" Value="#F74C5B"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </RadioButton.Resources>
                </RadioButton>
            </StackPanel>

            <!-- 1.4 搜索框 -->
            <Grid Grid.Column="6" VerticalAlignment="Center">
                <TextBox Height="36"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Background="#1B1C28"
                         BorderBrush="#333645"
                         BorderThickness="1"
                         Foreground="#FFFFFF"
                         FontSize="14"
                         Padding="30,0,10,0"
                         VerticalContentAlignment="Center"
                         materialDesign:HintAssist.Hint="{root:Loc 搜索事件消息...}"
                         materialDesign:HintAssist.Foreground="#5C6070"
                         materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"/>
                <materialDesign:PackIcon Kind="Magnify"
                                         Width="16"
                                         Height="16"
                                         Foreground="#5C6070"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="10,0,0,0"/>
            </Grid>
        </Grid>

        <!-- 2. Tabs -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <RadioButton Content="{root:Loc 运行日志}"
                         Style="{StaticResource LogTabButtonStyle}"
                         FontSize="15"
                         IsChecked="{Binding SelectedTab, Converter={StaticResource StringEqualsToBoolConverter}, ConverterParameter=运行日志, Mode=TwoWay}"/>
            <RadioButton Content="{root:Loc 操作日志}"
                         Style="{StaticResource LogTabButtonStyle}"
                         FontSize="15"
                         IsChecked="{Binding SelectedTab, Converter={StaticResource StringEqualsToBoolConverter}, ConverterParameter=操作日志, Mode=TwoWay}"/>
        </StackPanel>

        <!-- 3. Main DataGrid -->
        <DataGrid x:Name="LogGrid" Grid.Row="3"
                  ItemsSource="{Binding Notifications}"
                  AutoGenerateColumns="False"
                  HeadersVisibility="Column"
                  Background="#13141E"
                  BorderThickness="1"
                  BorderBrush="#1A1D2A"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#191C28"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeRows="False"
                  CanUserReorderColumns="False"
                  FontFamily="Segoe UI"
                  FontSize="15"
                  RowHeight="48"
                  ColumnHeaderHeight="40"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  SelectionUnit="FullRow">
            
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#171A24"/>
                    <Setter Property="Foreground" Value="#8A92A6"/>
                    <Setter Property="FontFamily" Value="Segoe UI"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="Padding" Value="20,0"/>
                    <Setter Property="Height" Value="40"/>
                    <Setter Property="BorderBrush" Value="#1E2130"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="20,0"/>
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                </Style>
            </DataGrid.CellStyle>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <!-- INFO: 标准暗底 -->
                    <Setter Property="Background" Value="#13141E"/>
                    <Setter Property="Foreground" Value="#E8EDF2"/>
                    <Setter Property="FontFamily" Value="Segoe UI"/>
                    <Setter Property="FontSize" Value="15"/>
                    <Setter Property="BorderBrush" Value="#1A1D2A"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Style.Triggers>
                        <!-- ERROR 行: 极淡暗红底，约 10% 不透明度 wash -->
                        <DataTrigger Binding="{Binding TypeDisplay}" Value="报警">
                            <Setter Property="Background" Value="#16200A08"/>
                            <Setter Property="Foreground" Value="#FFD6D6"/>
                        </DataTrigger>
                        <!-- WARN 行: 极淡琥珀底 wash -->
                        <DataTrigger Binding="{Binding TypeDisplay}" Value="维护">
                            <Setter Property="Background" Value="#16201108"/>
                            <Setter Property="Foreground" Value="#FFEAC4"/>
                        </DataTrigger>
                        <!-- 常规 INFO 行 -->
                        <DataTrigger Binding="{Binding TypeDisplay}" Value="系统">
                            <Setter Property="Background" Value="#13141E"/>
                            <Setter Property="Foreground" Value="#E8EDF2"/>
                        </DataTrigger>
                        <!-- 悬停高亮 -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#252736"/>
                        </Trigger>
                        <!-- 选中行 -->
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#2D324A"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <!-- 时间戳: Consolas 等宽字体确保垂直对齐 -->
                <DataGridTemplateColumn Header="{root:Loc 时间}" Width="210">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Timestamp}"
                                       FontFamily="Consolas"
                                       FontSize="14"
                                       Foreground="#B0B8CC"
                                       VerticalAlignment="Center"
                                       Margin="0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- 级别 badge -->
                <DataGridTemplateColumn Header="{root:Loc 级别}" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border x:Name="LevelBadge"
                                    Width="62"
                                    Height="24"
                                    CornerRadius="3"
                                    BorderThickness="0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="LevelText"
                                           Text="INFO"
                                           FontFamily="Segoe UI"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <DataTemplate.Triggers>
                                <!-- INFO: 暗灰底 + 亮灰字 -->
                                <DataTrigger Binding="{Binding TypeDisplay}" Value="系统">
                                    <Setter TargetName="LevelBadge" Property="Background" Value="#33384D"/>
                                    <Setter TargetName="LevelText" Property="Text" Value="INFO"/>
                                    <Setter TargetName="LevelText" Property="Foreground" Value="#D0D6E6"/>
                                </DataTrigger>
                                <!-- WARN: 纯实色琥珀底 + 深色字 -->
                                <DataTrigger Binding="{Binding TypeDisplay}" Value="维护">
                                    <Setter TargetName="LevelBadge" Property="Background" Value="#F5A623"/>
                                    <Setter TargetName="LevelText" Property="Text" Value="WARN"/>
                                    <Setter TargetName="LevelText" Property="Foreground" Value="#1A1200"/>
                                </DataTrigger>
                                <!-- ERROR: 纯实色红底 + 白字 -->
                                <DataTrigger Binding="{Binding TypeDisplay}" Value="报警">
                                    <Setter TargetName="LevelBadge" Property="Background" Value="#FF4D4D"/>
                                    <Setter TargetName="LevelText" Property="Text" Value="ERROR"/>
                                    <Setter TargetName="LevelText" Property="Foreground" Value="#FFFFFF"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- 来源/机台 -->
                <DataGridTemplateColumn Header="{root:Loc 来源/机台}" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Source}"
                                       FontFamily="Segoe UI"
                                       FontSize="15"
                                       FontWeight="Medium"
                                       Foreground="#C8D0E0"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- 事件消息 -->
                <DataGridTemplateColumn Header="{root:Loc 消息内容}" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Content}"
                                       FontFamily="Segoe UI"
                                       FontSize="15"
                                       Foreground="#FFFFFF"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 4. Bottom Pagination -->
        <Grid Grid.Row="4" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 左下角统计 -->
            <TextBlock Foreground="#5C6070" FontSize="12" xml:space="preserve" VerticalAlignment="Center"><Run Text="{root:Loc 显示第}"/> <Run Text="{Binding CurrentPageStart, Mode=OneWay}" Foreground="#8A8D99"/> <Run Text="{root:Loc 到}"/> <Run Text="{Binding CurrentPageEnd, Mode=OneWay}" Foreground="#8A8D99"/> <Run Text="{root:Loc 条，共}"/> <Run Text="{Binding TotalRecords, Mode=OneWay}" Foreground="#8A8D99"/> <Run Text="{root:Loc 条记录}"/></TextBlock>
            
            <!-- 右下角分页控制 -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                <!-- 上一页 -->
                <Button Command="{Binding PreviousPageCommand}" Style="{StaticResource PaginationButtonStyle}" Width="64" Height="28">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ChevronLeft" Width="14" Height="14" VerticalAlignment="Center"/>
                        <TextBlock Text="{root:Loc 上一页}" FontSize="11" Margin="2,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <!-- 页码 -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                    <TextBlock Text="{root:Loc 第}" Foreground="#8A8D99" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentPage}" Foreground="#FFFFFF" FontWeight="Bold" FontSize="12" Margin="4,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{root:Loc '页 / 共'}" Foreground="#8A8D99" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalPages}" Foreground="#FFFFFF" FontWeight="Bold" FontSize="12" Margin="4,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{root:Loc 页}" Foreground="#8A8D99" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
                <!-- 下一页 -->
                <Button Command="{Binding NextPageCommand}" Style="{StaticResource PaginationButtonStyle}" Width="64" Height="28">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{root:Loc 下一页}" FontSize="11" Margin="0,0,2,0" VerticalAlignment="Center"/>
                        <materialDesign:PackIcon Kind="ChevronRight" Width="14" Height="14" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
