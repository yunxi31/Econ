<Window x:Class="MotorTestSystem.Views.ModernMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:root="clr-namespace:MotorTestSystem"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Width="440"
        SizeToContent="Height"
        MinWidth="380"
        MaxWidth="600"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent"
        ShowInTaskbar="False"
        FontFamily="Microsoft YaHei UI">

    <Border Background="#12181F"
            BorderBrush="#334052"
            BorderThickness="1.5"
            CornerRadius="12"
            Margin="15">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="0" Opacity="0.6"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="45"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" 
                    Background="#18212B" 
                    CornerRadius="10,10,0,0" 
                    BorderBrush="#25313F" 
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="16,0,8,0">
                    <TextBlock x:Name="TitleText" 
                               Text="{root:Loc 系统提示}" 
                               Foreground="#12DDF7" 
                               FontSize="14" 
                               FontWeight="Bold" 
                               VerticalAlignment="Center"/>
                    <Button HorizontalAlignment="Right" 
                            Width="30" 
                            Height="30" 
                            VerticalAlignment="Center"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="#A7B1BA"
                            Padding="0"
                            Click="CloseButton_Click"
                            Cursor="Hand">
                        <materialDesign:PackIcon Kind="Close" Width="18" Height="18"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Message Area -->
            <Grid Grid.Row="1" Margin="24,20,24,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Icon -->
                <materialDesign:PackIcon x:Name="MsgIcon" 
                                         Kind="InformationOutline" 
                                         Width="36" 
                                         Height="36" 
                                         Foreground="#12DDF7" 
                                         VerticalAlignment="Top" 
                                         Margin="0,2,16,0"/>

                <!-- Message Text -->
                <TextBlock Grid.Column="1" 
                           x:Name="MessageText" 
                           Text="{root:Loc 提示内容}" 
                           Foreground="#D7DEE7" 
                           FontSize="14" 
                           LineHeight="20"
                           TextWrapping="Wrap" 
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- Buttons Area -->
            <Border Grid.Row="2" 
                    Background="#18212B" 
                    CornerRadius="0,0,10,10" 
                    BorderBrush="#25313F" 
                    BorderThickness="0,1,0,0"
                    Padding="16,12">
                <StackPanel x:Name="ButtonsPanel" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Right">
                    
                    <Button x:Name="BtnCancel" 
                            Content="{root:Loc 取消}" 
                            Width="90" 
                            Height="32" 
                            Margin="0,0,12,0"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            BorderBrush="#4F6075"
                            Foreground="#A7B1BA"
                            Click="BtnCancel_Click"
                            Visibility="Collapsed"/>

                    <Button x:Name="BtnOK" 
                            Content="{root:Loc 确定}" 
                            Width="90" 
                            Height="32" 
                            Style="{StaticResource MaterialDesignFlatMidBgButton}"
                            Background="#12DDF7"
                            BorderBrush="#12DDF7"
                            Foreground="#090E12"
                            FontWeight="Bold"
                            Click="BtnOK_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
